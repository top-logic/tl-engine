<?xml version="1.0" encoding="utf-8" ?>

<view>
	<stack
		direction="column"
		gap="default"
	>
		<grid
			gap="default"
			min-column-width="16rem"
		>
			<card
				title="Active Tasks"
				variant="elevated"
			>
				<demo-counter label="Tasks"/>
			</card>
			<card title="In Review">
				<demo-counter label="Reviews"/>
			</card>
			<card title="Team Notes">
				<button>
					<action class="com.top_logic.demo.view.command.OpenDemoDialogCommand"
						label="Open Details"
						dialog-title="Team Notes"
						dialog-message="Here are the latest team notes and updates."
					/>
				</button>
			</card>
			<card title="Quick Add">
				<button>
					<action class="com.top_logic.demo.view.command.OpenDemoDialogCommand"
						label="+ New Task"
						dialog-title="New Task"
						dialog-message="Enter your new task details here."
					/>
				</button>
			</card>
			<card title="Multi-Window Demo">
				<button>
					<action class="com.top_logic.demo.view.command.OpenWindowDemoCommand"
						label="Open Child Window"
					/>
				</button>
			</card>
		</grid>
	</stack>
</view>