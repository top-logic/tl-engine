<?xml version="1.0" encoding="utf-8" ?>

<application config:interface="com.top_logic.basic.config.ApplicationConfig$Config"
	xmlns:config="http://www.top-logic.com/ns/config/6.0"
>
	<services>
		<config service-class="com.top_logic.basic.util.ResourcesModule">
			<instance>
				<bundles>
					<bundle name="model.tl.devtools.messages"/>
				</bundles>
			</instance>
		</config>
		<config service-class="com.top_logic.util.model.ModelService">
			<instance class="com.top_logic.element.model.DynamicModelService">
				<declarations>
					<declaration file="/WEB-INF/model/tl.devtools.model.xml"/>
				</declarations>
			</instance>
		</config>

		<!--
			Contribute the Model admin section (the model editor) into the admin view's "admin"
			extension point. The admin view lives in tl-layout-view, which does not depend on this
			module; the section appears only in apps that include tl-dev-tools. Inserted right after
			the static "system" tab so the order stays Access control, Monitoring, System, Model,
			Development (the Development section appends at the end).
		-->
		<config service-class="com.top_logic.layout.view.contribution.ViewContributionService">
			<instance>
				<extensions>
					<extension id="admin">
						<tab-bar>
							<tab id="model-editor"
								config:operation="add"
								config:position="after"
								config:reference="system"
							>
								<label>
									<en>Model</en>
									<de>Modell</de>
								</label>
								<view-ref view="admin/model/model-editor.view.xml"/>
							</tab>
						</tab-bar>
					</extension>
				</extensions>
			</instance>
		</config>
	</services>
</application>
