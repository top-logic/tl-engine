<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<!-- The currently active session user, for display in the app bar. -->
		<derived-channel name="currentPerson"
			expr="currentUser()"
		/>
	</channels>
	<app-shell>
		<content>
			<sidebar
				active-item="attributes"
				drawer-open-slot-name="appbar-leading"
			>
				<items>
					<nav-item id="attributes"
						icon="css:bi bi-card-list"
					>
						<view-ref view="attributes.view.xml"/>
						<label>
							<en>Attributes</en>
							<de>Attribute</de>
						</label>
					</nav-item>
					<nav-item id="tickets"
						icon="css:bi bi-chat-left-text"
					>
						<view-ref view="tickets.view.xml"/>
						<label>
							<en>Tickets</en>
							<de>Tickets</de>
						</label>
					</nav-item>
					<separator/>
					<nav-item id="administration"
						icon="css:bi bi-shield-lock"
						route="none"
					>
						<access-control scope="administration"/>
						<view-ref view="admin/admin.view.xml"/>
						<label>
							<en>Administration</en>
							<de>Administration</de>
						</label>
					</nav-item>
				</items>
			</sidebar>
		</content>
		<header>
			<app-bar variant="flat">
				<commands>
					<open-designer placement="TOOLBAR" image="css:bi bi-easel">
						<label>
							<en>Designer</en>
							<de>Designer</de>
						</label>
						<tooltip>
							<en>Open the view designer to edit the current page.</en>
							<de>Öffnet den View-Designer zur Bearbeitung der aktuellen Seite.</de>
						</tooltip>
					</open-designer>

					<!--
						Pops out the script-recorder side-window: a generic open-window command configured
						with the recorder view.
					-->
					<open-window
						height="320"
						image="css:bi bi-record-circle"
						placement="TOOLBAR"
						singleton-key="script-recorder"
						view="script-recorder.view.xml"
						width="420"
					>
						<title>
							<en>Script Recorder</en>
							<de>Skript-Rekorder</de>
						</title>
						<label>
							<en>Record</en>
							<de>Aufzeichnen</de>
						</label>
						<tooltip>
							<en>Open the script recorder to capture interactions as a replayable script.</en>
							<de>Öffnet den Skript-Rekorder, um Interaktionen als abspielbares Skript aufzuzeichnen.</de>
						</tooltip>
						<executability>
							<authenticated-only/>
						</executability>
					</open-window>

					<!-- Login: shown only for the anonymous user; opens the login dialog. -->
					<generic-command
						image="css:bi bi-box-arrow-in-right"
						placement="TOOLBAR"
					>
						<label>
							<en>Login</en>
							<de>Anmeldung</de>
						</label>
						<executability>
							<anonymous-only/>
						</executability>
						<execute-script function="x -> new(`tl.login:Credentials`, transient: true)"/>
						<open-dialog
							bind-input-to="model"
							close-on-backdrop="false"
							dialog-view="login.view.xml"
						/>
					</generic-command>

					<!-- Logout: shown only for an authenticated user. -->
					<logout-command
						image="css:bi bi-box-arrow-right"
						placement="TOOLBAR"
					>
						<label>
							<en>Logout</en>
							<de>Abmeldung</de>
						</label>
						<executability>
							<authenticated-only/>
						</executability>
					</logout-command>
				</commands>
				<title>
					<en>TopLogic React Demo</en>
					<de>TopLogic React Demo</de>
				</title>
				<leading>
					<!--
						Mobile drawer-toggle target. The sidebar above is configured with
						drawer-open-slot-name="appbar-leading", which makes it contribute a
						hamburger button into this slot via the slot-content registry; CSS makes
						it visible only at small viewports. The two names must match.
					-->
					<slot name="appbar-leading"/>
				</leading>
				<children>
					<text
						css-class="tlAppBarUser"
						input="currentPerson"
						overflow="ellipsis"
					/>
				</children>
			</app-bar>
		</header>
	</app-shell>
</view>