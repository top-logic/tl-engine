<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="selectedObject"/>
	</channels>
	<split-panel
		orientation="horizontal"
		resizable="true"
	>
		<panes>
			<pane
				min-size="200"
				size="30"
				unit="%"
			>
				<panel>
					<title>
						<en>Constraint Test Objects</en>
						<de>Constraint-Test-Objekte</de>
					</title>
					<commands>
						<generic-command placement="TOOLBAR">
							<label>
								<en>New</en>
								<de>Neu</de>
							</label>
							<execute-script function="x -> new(`test.constraints:ConstraintTestType`, transient: true)"/>
							<open-dialog
								bind-input-to="model"
								dialog-view="demo/create-constraint-test.view.xml"
							>
								<bind
									channel="selection"
									to="selectedObject"
								/>
							</open-dialog>
						</generic-command>
					</commands>
					<table
						observed-types="test.constraints:ConstraintTestType"
						selection="selectedObject"
						types="test.constraints:ConstraintTestType"
					>
						<rows>all(`test.constraints:ConstraintTestType`)</rows>
					</table>
				</panel>
			</pane>
			<pane
				size="70"
				unit="%"
			>
				<panel>
					<title>
						<en>Constraint Test Form</en>
						<de>Constraint-Test-Formular</de>
					</title>
					<form input="selectedObject">
						<field attribute="mandatoryString"/>
						<field attribute="sizedString"/>
						<field attribute="mandatorySizedString"/>
						<field attribute="rangedInt"/>
						<field attribute="rangedDouble"/>
						<field attribute="uppercaseStart"/>
						<field attribute="warningField"/>
						<field attribute="freeText"/>
						<composition-table attribute="items">
							<columns>
								<column attribute="name"/>
								<column attribute="quantity"/>
								<column attribute="unitPrice"/>
							</columns>
							<detail-dialog
								edit-mode-channel="editMode"
								height="300"
								input-channel="editedItem"
								layout="demo/edit-constraint-test-item.view.xml"
								width="500"
							/>
						</composition-table>
					</form>
				</panel>
			</pane>
		</panes>
	</split-panel>
</view>