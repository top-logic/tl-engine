<?xml version="1.0" encoding="utf-8" ?>

<role-rules config:interface="com.top_logic.element.boundsec.manager.rule.config.RoleRulesConfig"
	xmlns:config="http://www.top-logic.com/ns/config/6.0"
>
	<rules>
		<rule
			inherit="true"
			meta-element="projElement:projElement.All"
			resource-key="roleRule.assignedResponsible"
			role="projElement.Verantwortlicher"
		>
			<path>
				<step attribute="projElement:projElement.All#Verantwortlicher"/>
			</path>
		</rule>
		<rule
			inherit="true"
			meta-element="projElement:projElement.All"
			resource-key="roleRule.assignedMember"
			role="projElement.Mitarbeiter"
		>
			<path>
				<step attribute="projElement:projElement.All#Mitarbeiter"/>
			</path>
		</rule>

		<rule
			inherit="true"
			meta-element="projElement:projElement.All"
			resource-key="roleRule.inheritedResponsible"
			role="projElement.Mitarbeiter,projElement.Verantwortlicher"
			type="inheritance"
		>
			<path>
				<step
					attribute="projElement:ProjElementContainer#children"
					inverse="true"
				/>
			</path>
		</rule>

		<rule
			inherit="true"
			meta-element="projElement:projElement.ProjectRoot"
			resource-key="roleRule.subResponsible"
			role="projElement.TeilprojektVerantwortlicher"
			source-role="projElement.TeilprojektVerantwortlicher,projElement.Verantwortlicher"
			type="inheritance"
		>
			<path>
				<step attribute="projElement:projElement.ProjectRoot#children"/>
			</path>
		</rule>

		<rule
			inherit="true"
			meta-element="projElement:projElement.All"
			resource-key="roleRule.allUsers"
			role="projElement.Nutzer"
		>
			<path>
				<script-step expr="`SecurityStructure#ROOT`"/>
				<step attribute="SecurityStructure:SecurityStructure.Root#Nutzer"/>
			</path>
		</rule>
		<rule
			inherit="false"
			meta-element="projElement:Project"
			resource-key="roleRule.mainUsers"
			role="projElement.Hauptbenutzer"
		>
			<path>
				<script-step expr="`SecurityStructure#ROOT`"/>
				<step attribute="SecurityStructure:SecurityStructure.Root#Hauptbenutzer"/>
			</path>
		</rule>

		<rule
			inherit="true"
			meta-element="projElement:projElement.Part"
			resource-key="roleRule.observer"
			role="projElement.Nutzer"
			source-role="projElement.Beobachter"
			type="inheritance"
		>
			<path>
				<script-step expr="`SecurityStructure#ROOT`"/>
			</path>
		</rule>
		<rule
			inherit="true"
			meta-element="projElement:projElement.All"
			resource-key="roleRule.projectObserver"
			role="projElement.Projektbeobachter"
			type="inheritance"
		>
			<path>
				<script-step expr="`SecurityStructure#ROOT`"/>
			</path>
		</rule>

		<rule
			inherit="true"
			meta-element="projElement:projElement.All"
			resource-key="roleRule.dependendResponsible"
			role="projElement.Verantwortlicher"
		>
			<path>
				<step attribute="projElement:projElement.All#AbhaengigVon"/>
				<step attribute="projElement:projElement.All#Verantwortlicher"/>
			</path>
		</rule>
		<rule
			inherit="true"
			meta-element="projElement:projElement.All"
			resource-key="roleRule.dependendMember"
			role="projElement.Mitarbeiter"
		>
			<path>
				<step
					attribute="projElement:projElement.All#AbhaengigVon"
					inverse="true"
				/>
				<step attribute="projElement:projElement.All#Verantwortlicher"/>
			</path>
		</rule>
	</rules>
</role-rules>