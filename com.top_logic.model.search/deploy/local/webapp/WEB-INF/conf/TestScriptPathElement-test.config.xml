<?xml version="1.0" encoding="utf-8" ?>

<application>
	<services>
		<config service-class="com.top_logic.util.model.ModelService">
			<instance>
				<declarations>
					<declaration file="/WEB-INF/model/TestScriptPathElement.model.xml"/>
				</declarations>
				<settings>
					<module name="TestScriptPathElement">
						<roles>
							<role name="TestScriptPathElement.Reader"/>
							<role name="TestScriptPathElement.Writer"/>
						</roles>
					</module>
				</settings>
			</instance>
		</config>
		<config service-class="com.top_logic.tool.boundsec.manager.AccessManager">
			<instance>
				<role-rules>
					<rules>
						<rule
							meta-element="TestScriptPathElement:Assignment"
							role="TestScriptPathElement.Writer"
						>
							<path>
								<step attribute="TestScriptPathElement:Assignment#writers"/>
							</path>
						</rule>
						<rule
							meta-element="TestScriptPathElement:Assignment"
							role="TestScriptPathElement.Reader"
						>
							<path>
								<step attribute="TestScriptPathElement:Assignment#readers"/>
							</path>
						</rule>
						<inheritance-rule
							meta-element="TestScriptPathElement:Assembly"
							role="TestScriptPathElement.Reader"
						>
							<path>
								<step attribute="TestScriptPathElement:Assembly#area"/>
								<script-step>
									<expr><![CDATA[areaInstance -> {
										plant = $areaInstance
												.referers(`TestScriptPathElement:Assembly#area`)
												.singleElement()
												.get(`TestScriptPathElement:Assembly#plant`)
												.get(`TestScriptPathElement:Plant#name`)
												;
									
										$areaInstance
										.get(`TestScriptPathElement:ZAreaInstance#template`)
										.referers(`TestScriptPathElement:Assignment#area`)
										.filter(assignment -> 
											$assignment
											.get(`TestScriptPathElement:Assignment#plant`)
											.get(`TestScriptPathElement:Plant#name`)
											.containsElement($plant)
										)}]]></expr>
								</script-step>
							</path>
						</inheritance-rule>
					</rules>
				</role-rules>
			</instance>
		</config>
	</services>
</application>