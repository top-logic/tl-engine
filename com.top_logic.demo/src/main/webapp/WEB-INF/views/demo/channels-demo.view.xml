<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="selectedCompany"/>
	</channels>
	<split-panel
		orientation="horizontal"
		resizable="true"
	>
		<panes>
			<pane
				min-size="200"
				size="40"
				unit="%"
			>
				<panel title="Companies">
					<table
						selection="selectedCompany"
						types="Contacts:CompanyContact"
					>
						<rows>all(`Contacts:CompanyContact`)</rows>
					</table>
				</panel>
			</pane>
			<pane
				size="60"
				unit="%"
			>
				<panel title="Staff">
					<table types="Contacts:PersonContact">
						<inputs>
							<input channel="selectedCompany"/>
						</inputs>
						<rows>company -&gt; if($company == null, list(), $company.get(`Contacts:Contact.Company#staff`))</rows>
					</table>
				</panel>
			</pane>
		</panes>
	</split-panel>
</view>