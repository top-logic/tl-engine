<?xml version="1.0" encoding="iso-8859-1" ?>

<view>
	<channels>
		<channel name="model"/>
		<channel name="selection"/>
	</channels>
	<window
		width="600px"
	>
		<title>
			<en>New Constraint Test Object</en>
			<de>Neues Constraint-Test-Objekt</de>
		</title>
		<form input="model" initial-edit-mode="true" mode-switch="false">
			<field attribute="mandatoryString"/>
			<field attribute="sizedString"/>
			<field attribute="mandatorySizedString"/>
			<field attribute="rangedInt"/>
			<field attribute="rangedDouble"/>
			<field attribute="uppercaseStart"/>
			<field attribute="warningField"/>
			<field attribute="freeText"/>
			<composition-table attribute="items">
				<columns>
					<column attribute="name"/>
					<column attribute="quantity"/>
					<column attribute="unitPrice"/>
				</columns>
			</composition-table>
			<commands>
				<generic-command placement="TOOLBAR">
					<label>
						<en>Create</en>
						<de>Erstellen</de>
					</label>
					<store-form-state/>
					<with-transaction>
						<execute-script function="obj -> $obj.copy(transient: false)"/>
					</with-transaction>
					<write-channel name="selection"/>
					<close-dialog/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand">
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>
