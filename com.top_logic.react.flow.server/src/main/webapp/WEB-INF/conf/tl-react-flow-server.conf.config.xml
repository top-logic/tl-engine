<?xml version="1.0" encoding="utf-8" ?>

<application xmlns:config="http://www.top-logic.com/ns/config/6.0">
	<services>
		<config service-class="com.top_logic.basic.module.ModuleSystem">
			<instance class="com.top_logic.basic.module.ModuleSystem">
				<modules>
					<module key="com.top_logic.react.flow.server.axis.AxisProviderService$Module" value="true"/>
				</modules>
			</instance>
		</config>
		<config service-class="com.top_logic.gui.JSFileCompiler">
			<instance>
				<additional-files>
					<file resource="tl-react-flow-controls.js" type="module" />
					<file resource="/TLReactFlowClient/TLReactFlowClient.nocache.js" />
				</additional-files>
			</instance>
		</config>
		<config service-class="com.top_logic.react.flow.server.axis.AxisProviderService">
			<instance class="com.top_logic.react.flow.server.axis.AxisProviderService">
				<providers>
					<provider class="com.top_logic.react.flow.server.axis.providers.DaysSinceEpochAxisProvider"/>
				</providers>
			</instance>
		</config>
	</services>
</application>
