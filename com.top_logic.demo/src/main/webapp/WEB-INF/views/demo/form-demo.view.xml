<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="selectedPerson"/>
		<derived-channel name="selectedContact"
			expr="person -> $person.get(`tl.accounts:Person#contact`)"
			inputs="selectedPerson"
		/>
	</channels>
	<split-panel
		orientation="horizontal"
		resizable="true"
	>
		<panes>
			<pane
				min-size="200"
				size="40"
				unit="%"
			>
				<panel title="Accounts">
					<table
						selection="selectedPerson"
						types="tl.accounts:Person"
					>
						<rows>all(`tl.accounts:Person`)</rows>
					</table>
				</panel>
			</pane>
			<pane
				size="60"
				unit="%"
			>
				<panel title="Contact Details">
					<form input="selectedContact">
						<field attribute="firstname"/>
						<field attribute="name"/>
						<field attribute="phone"/>
						<field attribute="email"/>
					</form>
				</panel>
			</pane>
		</panes>
	</split-panel>
</view>