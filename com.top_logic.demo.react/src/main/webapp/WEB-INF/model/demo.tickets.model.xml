<?xml version="1.0" encoding="utf-8" ?>

<model xmlns="http://www.top-logic.com/ns/dynamic-types/6.0">
	<modules>
		<module name="demo.tickets">
			<class name="Ticket">
				<annotations>
					<main-properties properties="name"/>
				</annotations>
				<attributes>
					<property name="name"
						mandatory="true"
						type="tl.core:String"
					/>
					<reference name="comments"
						composite="true"
						kind="forwards"
						multiple="true"
						ordered="true"
						type="Comment"
					/>
				</attributes>
			</class>
			<class name="Comment">
				<attributes>
					<property name="content"
						mandatory="true"
						type="tl.model.wysiwyg:Html"
					/>
					<reference name="author"
						kind="forwards"
						type="tl.accounts:Person"
					/>
					<property name="date"
						type="tl.core:DateTime"
					/>
					<reference name="cited"
						kind="forwards"
						type="Comment"
					/>
					<reference name="attachments"
						composite="true"
						kind="forwards"
						multiple="true"
						ordered="true"
						type="Attachment"
					>
						<annotations>
							<dynamic-visibility>
								<mode-selector class="com.top_logic.model.search.providers.ModeSelectorByExpression"
									function="comment -&gt; editMode -&gt; if ($editMode || $comment.get(`demo.tickets:Comment#attachments`).size() &gt; 0, &quot;default&quot;, &quot;hidden&quot;)"
								/>
							</dynamic-visibility>
						</annotations>
					</reference>
				</attributes>
			</class>
			<class name="Attachment">
				<annotations>
					<main-properties properties="name, data"/>
				</annotations>
				<attributes>
					<property name="name"
						type="tl.core:String"
					>
						<annotations>
							<storage-algorithm>
								<fallback-storage
									fallback-attribute="fileName"
									storage-attribute="customName"
								/>
							</storage-algorithm>
						</annotations>
					</property>
					<property name="customName"
						type="tl.core:String"
					>
						<annotations>
							<visibility value="hidden"/>
						</annotations>
					</property>
					<property name="fileName"
						type="tl.core:String"
					>
						<annotations>
							<storage-algorithm>
								<query>
									<expr>x -&gt; label($x.get(`demo.tickets:Attachment#data`))</expr>
								</query>
							</storage-algorithm>
							<visibility value="hidden"/>
						</annotations>
					</property>
					<property name="data"
						mandatory="true"
						type="tl.core:Binary"
					/>
				</attributes>
			</class>
		</module>
	</modules>
</model>