<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="selectedObject"/>
	</channels>
	<split-panel
		orientation="horizontal"
		resizable="true"
	>
		<panes>
			<pane
				min-size="200"
				size="30"
				unit="%"
			>
				<panel title="Demo Types">
					<commands>
						<generic-command label="New" placement="TOOLBAR">
							<execute-script function="x -> { obj = new(`DemoTypes:A`, transient: true); $obj.set(`DemoTypes:DemoTypes.A#booleanMandatory`, true); $obj.set(`DemoTypes:DemoTypes.A#booleanRadioMandatory`, true); $obj.set(`DemoTypes:DemoTypes.A#booleanSelectMandatory`, true); $obj; }"/>
							<open-dialog
								dialog-view="demo/create-demo-type-a.view.xml"
								bind-input-to="model"
							>
								<bind channel="selection" to="selectedObject"/>
							</open-dialog>
						</generic-command>
						<command class="com.top_logic.layout.view.command.OpenDialogCommand"
							label="Show in Dialog"
							placement="TOOLBAR"
							dialog-view="demo/object-details-dialog.view.xml"
							close-on-backdrop="true"
						>
							<bind channel="model" to="selectedObject"/>
						</command>
					</commands>
					<table
						selection="selectedObject"
						types="DemoTypes:DemoTypes.A"
						observed-types="DemoTypes:A"
					>
						<rows>all(`DemoTypes:A`)</rows>
					</table>
				</panel>
			</pane>
			<pane
				size="70"
				unit="%"
			>
				<panel title="Object Details">
					<form input="selectedObject">
						<field attribute="name"/>
						<field attribute="color"/>
						<field attribute="string"/>
						<field attribute="boolean"/>
						<field attribute="date"/>
						<field attribute="float"/>
						<field attribute="icon"/>
						<field attribute="htmlDescription"/>
					</form>
				</panel>
			</pane>
		</panes>
	</split-panel>
</view>
