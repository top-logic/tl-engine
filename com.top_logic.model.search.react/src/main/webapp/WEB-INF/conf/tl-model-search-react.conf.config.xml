<?xml version="1.0" encoding="utf-8" ?>

<application xmlns:config="http://www.top-logic.com/ns/config/6.0">
	<services>
		<config service-class="com.top_logic.layout.react.resource.ClientResources">
			<instance class="com.top_logic.layout.react.resource.ClientResources">
				<resources>
					<module-script name="tl-script-editor"
						resource="/script/tl-script-editor.js"
						requires="tl-react-bridge,tl-code-editor"
					/>
					<stylesheet name="tl-script-editor-css"
						resource="/style/tlScriptEditor.css"
					/>
				</resources>
			</instance>
		</config>

		<!--
			Contribute the Development admin section (the TL-Script console) into the admin view's
			"admin.sections" extension point. The admin view lives in tl-layout-view, which does not
			depend on this module; this contribution adds the section only in apps that include this
			module.
		-->
		<config service-class="com.top_logic.layout.view.contribution.ViewContributionService">
			<instance class="com.top_logic.layout.view.contribution.ViewContributionService">
				<contributions>
					<contribution id="development"
						target="admin.sections"
						view="admin/development/section.view.xml"
						rank="1000"
					>
						<label>
							<en>Development</en>
							<de>Entwicklung</de>
						</label>
					</contribution>
				</contributions>
			</instance>
		</config>
	</services>
</application>
