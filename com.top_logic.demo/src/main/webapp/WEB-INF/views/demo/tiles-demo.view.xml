<?xml version="1.0" encoding="utf-8" ?>

<!--
	Drill-down tile navigation demo:
	- Outer view declares the navPath channel that holds the List<TileFrame> drill-down path.
	- The breadcrumb is contributed to the app bar via <slot-content to="secondary">; the
	app shell hosts the matching <slot name="secondary"/>, so the breadcrumb appears at the
	app-bar level rather than inside the tab. It reads the same channel; clicking a crumb
	truncates the path back to that depth.
	- The initial frame is a table of accounts; selecting one and clicking "Open" pushes a
	detail frame onto the stack.
-->
<view>
	<channels>
		<channel name="navPath"/>
	</channels>

	<stack>
		<slot-content to="secondary">
			<tile-breadcrumb path="navPath">
				<home-label>
					<en>Accounts</en>
					<de>Konten</de>
				</home-label>
			</tile-breadcrumb>
		</slot-content>

		<tile-stack
			initial="demo/tiles-demo/overview.view.xml"
			path="navPath"
		/>
	</stack>
</view>