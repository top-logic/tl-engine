{
  "mcpServers": {
    "trac": {
      "type": "stdio",
      "command": "tl-trac-mcp",
      "env": {
        "TRAC_URL": "http://tl/trac/login/xmlrpc"
      }
    },
    "jenkins": {
      "type": "stdio",
      "command": "tl-jenkins-mcp",
      "env": {
        "JENKINS_URL": "http://jenkins:8090/"
      }
    },
    "gitea": {
      "type": "stdio",
      "command": "tl-gitea-mcp",
      "env": {
        "GITEA_HOST": "https://git.top-logic.com"
      }
    }
  }
}
