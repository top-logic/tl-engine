<?xml version="1.0" encoding="utf-8"?>

<application xmlns:config="http://www.top-logic.com/ns/config/6.0">
	<services>
		<config service-class="com.top_logic.basic.util.ResourcesModule">
			<instance>
				<bundles>
					<bundle name="model.demo.react.messages"/>
				</bundles>
			</instance>
		</config>
		<config service-class="com.top_logic.util.model.ModelService">
			<instance>
				<declarations>
					<declaration file="/WEB-INF/model/demo.react.model.xml"/>
				</declarations>
			</instance>
		</config>

		<!--
			Demonstrates that view contributions generalize beyond tab bars: this contributes a
			navigation item into the app-shell sidebar's "app.sidebar" extension point (declared in
			app.view.xml), the same way tl-model-search-react contributes the Development tab into
			the admin tab bar.
		-->
		<config service-class="com.top_logic.layout.view.contribution.ViewContributionService">
			<instance>
				<contributions>
					<contribution id="contributed-section"
						target="app.sidebar"
						view="sidebar-contribution.view.xml"
						icon="css:bi bi-puzzle"
						rank="1000"
					>
						<label>
							<en>Contributed</en>
							<de>Beigesteuert</de>
						</label>
					</contribution>
				</contributions>

				<!--
					Refines the framework's "tl.view.playground" extension point (defined in
					tl-layout-view.conf.config.xml): inserts an application tab BEFORE the framework's
					"settings" tab. This uses only the typed-configuration list merge - keyed tabs plus
					config:position - so no rank arithmetic is needed and the framework module needs no
					knowledge of this contribution. Positioning before a static tab is exactly what the
					flat <contribution>/rank mechanism (used for the sidebar above) cannot express.
				-->
				<extensions>
					<extension id="tl.view.playground">
						<tab-bar>
							<tabs>
								<tab id="app-contributed"
									config:operation="add"
									config:position="before"
									config:reference="settings"
									icon="css:bi bi-plugin"
								>
									<label>
										<en>App tab</en>
										<de>App-Tab</de>
									</label>
									<panel>
										<title>
											<en>Application tab</en>
											<de>Anwendungs-Tab</de>
										</title>
										<text>
											<label>
												<en>This tab is contributed by the application (com.top_logic.demo.react) and inserted before the framework's Settings tab - through configuration merge alone, without touching the framework configuration.</en>
												<de>Dieser Tab wird von der Anwendung (com.top_logic.demo.react) beigesteuert und vor dem Settings-Tab des Frameworks eingefügt - allein durch Konfigurations-Merge, ohne die Framework-Konfiguration zu ändern.</de>
											</label>
										</text>
									</panel>
								</tab>
							</tabs>
						</tab-bar>
					</extension>
				</extensions>
			</instance>
		</config>
	</services>

	<configs>
		<!--
			This is a React-only application: its entry point is the React view shell at /view/.
			The framework's start page is a singleton setting that the legacy core defaults to the
			layout servlet; the application authoritatively declares its own entry here.
		-->
		<config config:interface="com.top_logic.base.accesscontrol.ApplicationPages$Config">
			<startPage>/view/</startPage>
		</config>
	</configs>
</application>
