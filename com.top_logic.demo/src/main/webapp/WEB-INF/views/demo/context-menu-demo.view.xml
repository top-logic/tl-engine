<?xml version="1.0" encoding="UTF-8" ?>

<view>
	<panel>
		<title>
			<en>Context Menu Demo</en>
			<de>Kontextmenue-Demo</de>
		</title>
		<context-menu>
			<commands>
				<generic-command placement="CONTEXT_MENU">
					<label>
						<en>Say Hello</en>
						<de>Hallo sagen</de>
					</label>
					<action class="com.top_logic.demo.view.command.SayHelloAction"/>
				</generic-command>
				<generic-command
					placement="CONTEXT_MENU"
					clique="DELETE"
				>
					<label>
						<en>Say Goodbye</en>
						<de>Tschuess sagen</de>
					</label>
					<action class="com.top_logic.demo.view.command.SayGoodbyeAction"/>
				</generic-command>
			</commands>
			<card variant="elevated">
				<title>
					<en>Right-click anywhere in this card to open the context menu.</en>
					<de>Rechtsklicken Sie in dieser Karte, um das Kontextmenue zu oeffnen.</de>
				</title>
			</card>
		</context-menu>
	</panel>
</view>
