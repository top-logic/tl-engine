<?xml version="1.0" encoding="utf-8" ?>

<config:template-call
	xmlns:config="http://www.top-logic.com/ns/config/6.0"
	template="com.top_logic.model.search/create/genericCreateDialog.template.xml"
>
	<arguments height="300px">
		<forms>
			<form type="tl.demo.projectManagement:Project">
				<formDefinition columns="ONE">
					<field
						attribute="name"
						fullQualifiedName="tl.demo.projectManagement:Project#name"
						type="tl.core:String"
					/>
					<field
						attribute="description"
						fullQualifiedName="tl.demo.projectManagement:Project#description"
						type="tl.core:String"
					/>
				</formDefinition>
			</form>
		</forms>
		<title>
			<title key="dynamic.undoRedo-newProject-title">
				<en>New project</en>
				<de>Neues Projekt</de>
			</title>
		</title>
		<open-handler id="undoRedo_newProject_open"
			config:interface="com.top_logic.layout.editor.config.CreateDialogOpenHandlerConfig"
			image="theme:ICONS_ADD_BUTTON"
		>
			<resourceKey key="dynamic.undoRedo-newProject-open">
				<en>New project</en>
				<de>Neues Projekt</de>
			</resourceKey>
		</open-handler>
		<typeOptions type="tl.demo.projectManagement:Project"/>
		<create-handler id="undoRedo_newProject_create">
			<postCreateActions>
				<setModel target="selection(com.top_logic.demo/technical/components/undoRedo/projectsTable.layout.xml#Table)">
					<input/>
				</setModel>
			</postCreateActions>
		</create-handler>
	</arguments>
</config:template-call>
