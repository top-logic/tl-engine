<?xml version="1.0" encoding="utf-8" ?>

<!--
	Dialog to add an attribute to the selected type. The form edits a transient NewAttribute model
	(bound to the model channel by the opening command): the attribute name, value type and cardinality
	(mandatory / multiple). The primary command stores the form state, runs the ModelEditAction in
	CREATE_ATTRIBUTE mode inside a transaction (adding the property to the type derived from the
	container channel), writes the new attribute to the selection channel bound to the parent view,
	bumps the reload channel so the diagram re-reads its module, and closes the dialog.
-->
<view>
	<channels>
		<channel name="model"/>
		<channel name="selection"/>
		<channel name="container"/>
		<channel name="reload"/>
	</channels>
	<window
		resizable="false"
		width="420px"
	>
		<title>
			<en>New attribute</en>
			<de>Neues Attribut</de>
		</title>
		<form
			initial-edit-mode="true"
			input="model"
			mode-switch="false"
		>
			<field attribute="name"/>
			<field attribute="type"/>
			<field attribute="mandatory"/>
			<field attribute="multiple"/>
			<commands>
				<generic-command
					image="css:bi bi-check-lg"
					placement="BUTTON_BAR"
				>
					<label>
						<en>Create</en>
						<de>Anlegen</de>
					</label>
					<store-form-state/>
					<with-transaction>
						<action class="com.top_logic.dev.tools.model.ModelEditAction"
							container="container"
							mode="CREATE_ATTRIBUTE"
						/>
					</with-transaction>
					<write-channel name="selection"/>
					<execute-script function="x -> now()"/>
					<write-channel name="reload"/>
					<close-dialog/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand"
					image="css:bi bi-x-lg"
				>
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>