<?xml version="1.0" encoding="utf-8" ?>

<!--
	Responsive master-detail demo exercising a multi-step (nested) selection path.
	
	A single <adaptive-detail> configuration renders differently per display class:
	- REGULAR (wide): cascading columns - project scopes | milestones | milestone detail.
	- COMPACT (narrow): step-by-step drill-in - scopes -> milestones -> detail, with a back bar.
	
	The level-2 selector lists the milestones of the scope selected in level 1 (its <rows>
	expression takes the selectedScope channel as input). The model builder / columns / form are
	each authored exactly once and shared by both presentations.
-->
<view>
	<channels>
		<channel name="selectedScope"/>
		<channel name="selectedMilestone"/>
	</channels>

	<panel>
		<title>
			<en>Responsive Master-Detail Demo</en>
			<de>Responsive Master-Detail-Demo</de>
		</title>

		<adaptive-detail selection="selectedScope">
			<home-label>
				<en>Project Scopes</en>
				<de>Projekt-Scopes</de>
			</home-label>
			<selector>
				<panel>
					<title>
						<en>Project Scopes</en>
						<de>Projekt-Scopes</de>
					</title>
					<commands>
						<generic-command
							image="css:bi bi-plus-lg"
							placement="TOOLBAR"
						>
							<label>
								<en>New Project Scope</en>
								<de>Neuer Projekt-Scope</de>
							</label>
							<execute-script function="x -> new(`tl.demo.projectManagement:ProjectScope`, transient: true)"/>
							<open-dialog
								bind-input-to="model"
								dialog-view="demo/create-project-scope.view.xml"
							>
								<bind
									channel="selection"
									to="selectedScope"
								/>
							</open-dialog>
						</generic-command>
					</commands>
					<table
						observed-types="tl.demo.projectManagement:ProjectScope"
						selection="selectedScope"
						types="tl.demo.projectManagement:ProjectScope"
					>
						<columns>
							<column attribute="name"/>
						</columns>
						<rows>all(`tl.demo.projectManagement:ProjectScope`)</rows>
					</table>
				</panel>
			</selector>
			<detail>
				<adaptive-detail
					reset-on="selectedScope"
					selection="selectedMilestone"
				>
					<selector>
						<panel>
							<title>
								<en>Milestones</en>
								<de>Meilensteine</de>
							</title>
							<commands>
								<generic-command
									image="css:bi bi-plus-lg"
									input="selectedScope"
									placement="TOOLBAR"
								>
									<label>
										<en>New Milestone</en>
										<de>Neuer Meilenstein</de>
									</label>
									<executability>
										<null-input-disabled/>
									</executability>
									<execute-script function="x -> new(`tl.demo.projectManagement:Milestone`, transient: true)"/>
									<open-dialog
										bind-input-to="model"
										dialog-view="demo/create-milestone.view.xml"
									>
										<bind
											channel="container"
											to="selectedScope"
										/>
										<bind
											channel="selection"
											to="selectedMilestone"
										/>
									</open-dialog>
								</generic-command>
							</commands>
							<table
								observed-types="tl.demo.projectManagement:Milestone"
								selection="selectedMilestone"
								types="tl.demo.projectManagement:Milestone"
							>
								<columns>
									<column attribute="name"/>
								</columns>
								<inputs>
									<input channel="selectedScope"/>
								</inputs>
								<rows>scope -&gt; if($scope == null, list(), $scope.get(`tl.demo.projectManagement:ProjectScope#milestones`))</rows>
							</table>
						</panel>
					</selector>
					<detail>
						<form input="selectedMilestone">
							<field attribute="name"/>
							<field attribute="dueDate"/>
						</form>
					</detail>
				</adaptive-detail>
			</detail>
		</adaptive-detail>
	</panel>
</view>