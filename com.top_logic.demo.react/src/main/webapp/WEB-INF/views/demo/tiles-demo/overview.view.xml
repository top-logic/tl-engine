<?xml version="1.0" encoding="utf-8" ?>

<!--
	Initial frame of the tile drill-down demo. Lists all Person accounts and
	offers an "Open" button that pushes a detail frame onto the enclosing
	tile-stack with the selected Person as parameter.
-->
<view>
	<channels>
		<channel name="selectedPerson"/>
	</channels>

	<panel>
		<title>
			<en>Accounts</en>
			<de>Konten</de>
		</title>
		<commands>
			<command class="com.top_logic.layout.view.tiles.NavigatePushCommand"
				bind-input-to="person"
				input="selectedPerson"
				placement="TOOLBAR"
				view="demo/tiles-demo/person-detail.view.xml"
			>
				<label>
					<en>Open</en>
					<de>Öffnen</de>
				</label>
				<frame-label class="com.top_logic.layout.view.tiles.ScriptedTileLabel"
					expr="p -> $p.get(`tl.accounts:Person#name`)"
					inputs="selectedPerson"
				/>
			</command>
		</commands>
		<table
			selection="selectedPerson"
			types="tl.accounts:Person"
		>
			<rows>all(`tl.accounts:Person`)</rows>
		</table>
	</panel>
</view>