<?xml version="1.0" encoding="iso-8859-1" ?>

<view>
	<tab-bar>
		<tabs>
			<tab id="featured" route="/featured">
				<label>
					<en>Featured</en>
					<de>Empfohlen</de>
				</label>
				<card variant="elevated">
					<title>
						<en>Featured Tab (routed)</en>
						<de>Empfohlen-Tab (geroutet)</de>
					</title>
					<panel>
						<title>
							<en>This tab produces URL segment /featured</en>
							<de>Dieser Tab erzeugt das URL-Segment /featured</de>
						</title>
					</panel>
				</card>
			</tab>
			<tab id="nearby" route="/nearby">
				<label>
					<en>Nearby</en>
					<de>In der N&#xe4;he</de>
				</label>
				<card variant="elevated">
					<title>
						<en>Nearby Tab (routed)</en>
						<de>In-der-N&#xe4;he-Tab (geroutet)</de>
					</title>
					<panel>
						<title>
							<en>This tab produces URL segment /nearby</en>
							<de>Dieser Tab erzeugt das URL-Segment /nearby</de>
						</title>
					</panel>
				</card>
			</tab>
			<tab id="internal">
				<label>
					<en>Internal (no route)</en>
					<de>Intern (kein Routing)</de>
				</label>
				<card variant="elevated">
					<title>
						<en>Internal Tab (NOT routed)</en>
						<de>Interner Tab (NICHT geroutet)</de>
					</title>
					<panel>
						<title>
							<en>This tab does NOT change the URL</en>
							<de>Dieser Tab &#xe4;ndert die URL NICHT</de>
						</title>
					</panel>
				</card>
			</tab>
		</tabs>
	</tab-bar>
</view>
