<application xmlns:config="http://www.top-logic.com/ns/config/6.0">
	<services>
		<config service-class="com.top_logic.util.model.ModelService">
			<instance>
				<declarations>
					<declaration file="/WEB-INF/model/demo.filter.model.xml"/>
				</declarations>
				<settings>
					<module name="demo.filter" />
				</settings>
			</instance>
		</config>

		<config service-class="com.top_logic.basic.util.ResourcesModule">
			<instance>
				<bundles>
					<bundle name="model.demo.filter.messages" />
				</bundles>
			</instance>
		</config>
	</services>
</application>
