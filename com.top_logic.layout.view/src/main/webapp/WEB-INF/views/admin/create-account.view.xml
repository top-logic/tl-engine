<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="model"/>
		<channel name="selection"/>
	</channels>
	<window
		width="500px"
	>
		<title>
			<en>New Account</en>
			<de>Neues Konto</de>
		</title>
		<form input="model"
			initial-edit-mode="true"
			mode-switch="false"
		>
			<field attribute="login"/>
			<commands>
				<generic-command placement="TOOLBAR">
					<label>
						<en>Create</en>
						<de>Erstellen</de>
					</label>
					<store-form-state/>
					<with-transaction>
						<create-account/>
					</with-transaction>
					<write-channel name="selection"/>
					<close-dialog/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand">
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>
