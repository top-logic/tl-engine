<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="model"/>
	</channels>
	<window
		title="Object Details"
		width="500px"
	>
		<form input="model">
			<field attribute="name"/>
			<field attribute="color"/>
			<field attribute="string"/>
			<field attribute="boolean"/>
			<field attribute="date"/>
			<field attribute="float"/>
			<field attribute="icon"/>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand"
					label="Close"
				/>
			</button>
		</actions>
	</window>
</view>
