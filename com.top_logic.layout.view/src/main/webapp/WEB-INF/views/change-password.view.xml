<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<!-- Transient PasswordChange model bound to the form. -->
		<channel name="model"/>
		<!-- The account whose expired password is being changed (set by LoginAction). -->
		<channel name="account"/>
	</channels>
	<window resizable="false"
			width="380px">
		<title>
			<en>Change password</en>
			<de>Passwort &#228;ndern</de>
		</title>
		<form input="model"
			initial-edit-mode="true"
			mode-switch="false"
		>
			<text>
				<label>
					<en>Your password has expired. Please choose a new password.</en>
					<de>Ihr Passwort ist abgelaufen. Bitte w&#228;hlen Sie ein neues Passwort.</de>
				</label>
			</text>
			<field attribute="newPassword"/>
			<field attribute="newPasswordConfirm"/>
			<commands>
				<generic-command placement="BUTTON_BAR" image="css:bi bi-key">
					<label>
						<en>Change password</en>
						<de>Passwort &#228;ndern</de>
					</label>
					<store-form-state/>
					<change-password/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand" image="css:bi bi-x-lg">
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>
