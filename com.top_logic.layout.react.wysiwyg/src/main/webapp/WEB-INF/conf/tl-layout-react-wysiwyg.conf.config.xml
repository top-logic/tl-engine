<?xml version="1.0" encoding="utf-8" ?>

<application xmlns:config="http://www.top-logic.com/ns/config/6.0">
  <services>
    <config service-class="com.top_logic.layout.view.form.FieldControlService">
      <instance class="com.top_logic.layout.view.form.FieldControlService">
        <providers>
          <provider type="tl.model.wysiwyg:Html">
            <impl class="com.top_logic.layout.react.wysiwyg.WysiwygControlProvider"/>
          </provider>
        </providers>
      </instance>
    </config>

    <config service-class="com.top_logic.gui.JSFileCompiler">
      <instance>
        <additional-files>
          <file resource="tl-react-wysiwyg.js" type="module" />
        </additional-files>
      </instance>
    </config>
  </services>
</application>
