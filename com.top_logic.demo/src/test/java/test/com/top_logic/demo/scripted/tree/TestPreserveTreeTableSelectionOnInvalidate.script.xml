<?xml version="1.0" encoding="utf-8" ?>

<action class="com.top_logic.layout.scripting.runtime.action.ActionChainOp"
	xmlns:config="http://www.top-logic.com/ns/config/6.0"
	comment="Test for ticket #29402: the selection of a tree-table node must survive an invalidate of the view instead of falling back to the default selection."
>
	<actions>
		<action class="com.top_logic.layout.scripting.runtime.action.ActionChainOp"
			comment="Setup"
		>
			<actions>
				<action class="com.top_logic.layout.scripting.template.action.op.ScriptTemplateActionOp"
					template="script:/Variable/Action-Variable-Alle loeschen.xml"
					template-name-comment="Variable Alle loeschen"
				/>
				<action class="com.top_logic.layout.scripting.template.action.op.ScriptTemplateActionOp"
					template="script:/demo/create-A.xml"
					template-name-comment="Element Anlegen"
				>
					<parameters>
						<parameter name="ergebnis"
							value="Ticket #29402"
						/>
						<parameter name="Name"
							value="Ticket #29402"
						/>
					</parameters>
				</action>
				<action class="com.top_logic.layout.scripting.template.action.op.ScriptTemplateActionOp"
					template="script:/demo/create-B.xml"
					template-name-comment="Element Anlegen"
				>
					<parameters>
						<parameter name="ergebnis"
							value="Ticket #29402.1"
						/>
						<parameter name="kontext"
							value="Ticket #29402"
						/>
						<parameter name="Name"
							value="Ticket #29402.1"
						/>
						<parameter name="Typ"
							value="Demo B"
						/>
					</parameters>
				</action>
				<action class="com.top_logic.layout.scripting.template.action.op.ScriptTemplateActionOp"
					template="script:/demo/create-A.xml"
					template-name-comment="Element Anlegen"
				>
					<parameters>
						<parameter name="ergebnis"
							value="Ticket #29402.1.1"
						/>
						<parameter name="kontext"
							value="Ticket #29402.1"
						/>
						<parameter name="Name"
							value="Ticket #29402.1.1"
						/>
					</parameters>
				</action>
			</actions>
		</action>
		<action class="com.top_logic.layout.scripting.runtime.action.ActionChainOp"
			comment="Test"
		>
			<actions>
				<action class="com.top_logic.layout.scripting.template.action.op.ScriptTemplateActionOp"
					template="script:/Sicht/Action-Sicht-Anzeigen.xml"
					template-name-comment="Sicht Anzeigen"
				>
					<parameters>
						<parameter name="Pfad"
							value="Tabellen > Baumbasierte Tabelle"
						/>
					</parameters>
				</action>
				<action class="com.top_logic.layout.scripting.runtime.action.CommandExecutionOp"
					comment="Expand the created root node so that its descendants become visible."
					failure-expected="false"
					user-id="root"
				>
					<model-name config:interface="com.top_logic.layout.tree.renderer.TreeCellRenderer$ToggleNaming$ToggleName"
						expand="true"
					>
						<context-model config:interface="com.top_logic.layout.table.component.DefaultTableDataName">
							<default-table-data-owner config:interface="com.top_logic.layout.scripting.recorder.ref.ui.FuzzyComponentNaming$Name"
								tab-path="Tabellen > Baumbasierte Tabelle > Demo demoTreeTable.xml"
							/>
						</context-model>
						<node config:interface="com.top_logic.layout.scripting.recorder.ref.ui.table.LabeledTableRowNaming$Name"
							name="Ticket #29402"
						/>
					</model-name>
				</action>
				<action class="com.top_logic.layout.scripting.runtime.action.CommandExecutionOp"
					comment="Expand the intermediate node."
					failure-expected="false"
					user-id="root"
				>
					<model-name config:interface="com.top_logic.layout.tree.renderer.TreeCellRenderer$ToggleNaming$ToggleName"
						expand="true"
					>
						<context-model config:interface="com.top_logic.layout.table.component.DefaultTableDataName">
							<default-table-data-owner config:interface="com.top_logic.layout.scripting.recorder.ref.ui.FuzzyComponentNaming$Name"
								tab-path="Tabellen > Baumbasierte Tabelle > Demo demoTreeTable.xml"
							/>
						</context-model>
						<node config:interface="com.top_logic.layout.scripting.recorder.ref.ui.table.LabeledTableRowNaming$Name"
							name="Ticket #29402.1"
						/>
					</model-name>
				</action>
				<action class="com.top_logic.layout.scripting.runtime.action.SelectActionOp"
					change-kind="ABSOLUTE"
					comment="Select a node other than the default selection."
					user-id="root"
				>
					<selection>
						<selectee config:interface="com.top_logic.layout.scripting.recorder.ref.ui.table.LabeledTableRowNaming$Name"
							name="Ticket #29402.1.1"
						/>
						<selection-state boolean="true"/>
					</selection>
					<selection-model-name config:interface="com.top_logic.layout.table.component.DefaultTableDataName">
						<default-table-data-owner config:interface="com.top_logic.layout.scripting.recorder.ref.ui.FuzzyComponentNaming$Name"
							tab-path="Tabellen > Baumbasierte Tabelle > Demo demoTreeTable.xml"
						/>
					</selection-model-name>
				</action>
				<action class="com.top_logic.layout.scripting.runtime.action.assertion.ValueAssertionOp"
					comment="The chosen node is selected before the invalidate."
					comparision="equals"
					user-id="root"
				>
					<actual-value config:interface="com.top_logic.layout.component.SelectableSelectionNaming$SelectableSelectionName">
						<selectable config:interface="com.top_logic.layout.scripting.recorder.ref.ui.FuzzyComponentNaming$Name"
							tab-path="Tabellen > Baumbasierte Tabelle > Demo demoTreeTable.xml"
						/>
					</actual-value>
					<expected-value config:interface="com.top_logic.layout.scripting.recorder.ref.value.object.GlobalVariableNaming$GlobalVariableName"
						name="Ticket #29402.1.1"
					/>
				</action>
				<action class="com.top_logic.layout.scripting.runtime.action.LabeledButtonActionOp"
					comment="Invalidate the view via the 'Aktualisieren' toolbar button; this discards and rebuilds the tree."
					component-name="rootLayout#masterFrame"
					label="Aktualisieren"
					user-id="root"
				/>
				<action class="com.top_logic.layout.scripting.runtime.action.assertion.ValueAssertionOp"
					comment="After the invalidate the selection is preserved and not reset to the default selection."
					comparision="equals"
					user-id="root"
				>
					<actual-value config:interface="com.top_logic.layout.component.SelectableSelectionNaming$SelectableSelectionName">
						<selectable config:interface="com.top_logic.layout.scripting.recorder.ref.ui.FuzzyComponentNaming$Name"
							tab-path="Tabellen > Baumbasierte Tabelle > Demo demoTreeTable.xml"
						/>
					</actual-value>
					<expected-value config:interface="com.top_logic.layout.scripting.recorder.ref.value.object.GlobalVariableNaming$GlobalVariableName"
						name="Ticket #29402.1.1"
					/>
				</action>
			</actions>
		</action>
		<action class="com.top_logic.layout.scripting.runtime.action.ActionChainOp"
			comment="Teardown"
		>
			<actions>
				<action class="com.top_logic.layout.scripting.template.action.op.ScriptTemplateActionOp"
					template="script:/Element/Action-Element-Loeschen.xml"
					template-name-comment="Element Loeschen"
				>
					<parameters>
						<parameter name="kontext"
							value="Ticket #29402.1.1"
						/>
					</parameters>
				</action>
				<action class="com.top_logic.layout.scripting.template.action.op.ScriptTemplateActionOp"
					template="script:/Element/Action-Element-Loeschen.xml"
					template-name-comment="Element Loeschen"
				>
					<parameters>
						<parameter name="kontext"
							value="Ticket #29402.1"
						/>
					</parameters>
				</action>
				<action class="com.top_logic.layout.scripting.template.action.op.ScriptTemplateActionOp"
					template="script:/Element/Action-Element-Loeschen.xml"
					template-name-comment="Element Loeschen"
				>
					<parameters>
						<parameter name="kontext"
							value="Ticket #29402"
						/>
					</parameters>
				</action>
				<action class="com.top_logic.layout.scripting.template.action.op.ScriptTemplateActionOp"
					template="script:/Variable/Action-Variable-Alle loeschen.xml"
					template-name-comment="Variable Alle loeschen"
				/>
			</actions>
		</action>
	</actions>
</action>
