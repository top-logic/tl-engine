<?xml version="1.0" encoding="utf-8" ?>

<model xmlns="http://www.top-logic.com/ns/dynamic-types/6.0">
	<module name="tl.login">
		<!--
			Transient-only type holding login form input. Instances are created with
			new(`tl.login:Credentials`, transient: true) and never persisted, so no table is
			declared.
		-->
		<class name="Credentials">
			<generalizations>
				<generalization type="tl.model:TLObject"/>
			</generalizations>
			<attributes>
				<property name="name"
					type="tl.core:String"
				/>
				<property name="password"
					type="tl.core:String"
				>
					<annotations>
						<input-control>
							<impl class="com.top_logic.layout.view.form.PasswordInputControlProvider"/>
						</input-control>
					</annotations>
				</property>
			</attributes>
		</class>

		<!--
			Transient-only type holding the input of the forced "change password" step that follows a
			login with an expired password. Instances are created in Java by LoginAction and bound to
			the change-password dialog's form; the account whose password is changed is transferred
			separately on the dialog's "account" channel.
		-->
		<class name="PasswordChange">
			<generalizations>
				<generalization type="tl.model:TLObject"/>
			</generalizations>
			<attributes>
				<property name="newPassword"
					type="tl.core:String"
				>
					<annotations>
						<input-control>
							<impl class="com.top_logic.layout.view.form.PasswordInputControlProvider"/>
						</input-control>
					</annotations>
				</property>
				<property name="newPasswordConfirm"
					type="tl.core:String"
				>
					<annotations>
						<input-control>
							<impl class="com.top_logic.layout.view.form.PasswordInputControlProvider"/>
						</input-control>
					</annotations>
				</property>
			</attributes>
		</class>

		<!--
			Transient-only type holding the one-time code entered in the MFA step of the login flow
			(OTP verification or enrollment confirmation). Instances are created in Java by
			LoginAction and bound to the OTP / enrollment dialog's form; the account, the secret and
			(for enrollment) the QR image are transferred separately on the dialog's "account",
			"secret" and "qr" channels.
		-->
		<class name="OtpEntry">
			<generalizations>
				<generalization type="tl.model:TLObject"/>
			</generalizations>
			<attributes>
				<property name="code"
					type="tl.core:String"
				/>
			</attributes>
		</class>
	</module>
</model>
