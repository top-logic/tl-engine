<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="comment"/>
		<derived-channel name="author"
			expr="c -> $c.get(`demo.tickets:Comment#author`)"
			inputs="comment"
		/>
		<derived-channel name="date"
			expr="c -> $c.get(`demo.tickets:Comment#date`)"
			inputs="comment"
		/>
	</channels>
	<panel
		appearance="card"
		command-display="icon-only"
		hover-actions="true"
	>
		<title-content>
			<avatar input="author"/>
			<text
				css-class="tlText--strong"
				input="author"
			/>
			<relative-time input="date"/>
		</title-content>
		<commands>
			<generic-command
				image="css:bi bi-trash"
				input="comment"
				placement="TOOLBAR"
			>
				<label>
					<en>Delete</en>
					<de>Löschen</de>
				</label>
				<remove-element/>
			</generic-command>
		</commands>
		<form input="comment">
			<field
				attribute="content"
				label-position="hide-label"
			/>
			<file-list attribute="attachments"/>
		</form>
	</panel>
</view>