<?xml version="1.0" encoding="utf-8" ?>

<config:template-call
	xmlns:config="http://www.top-logic.com/ns/config/6.0"
	template="com.top_logic.element/grid.template.xml"
>
	<arguments
		defaultColumns="name,factor,format,baseUnit,sortOrder"
		type="tl.units:Currency"
	>
		<name key="dynamic.5e82477f-7498-49f3-ae81-8dce14fd6ec4">
			<en>Currencies</en>
			<de>Währungen</de>
		</name>
		<modelBuilder class="com.top_logic.model.search.providers.ListModelByExpression"
			elements="model->all(`tl.units:Currency`)"
			supportsElement="element->$element.instanceOf(`tl.units:Currency`)"
		/>
		<buttons>
			<button id="exportExcelGrid"
				class="com.top_logic.layout.table.export.StreamingExcelExportHandler"
			/>
			<button id="createRow"
				class="com.top_logic.model.search.providers.GridCreateHandlerByExpression"
			>
				<checkScopeProvider/>
				<type-options
					include-subtypes="false"
					type="tl.units:Currency"
				/>
			</button>
			<button id="deleteRow"
				class="com.top_logic.layout.component.GenericDeleteCommandHandler"
				target="selection(self())"
			/>
		</buttons>
	</arguments>
</config:template-call>