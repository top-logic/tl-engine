<?xml version="1.0" encoding="utf-8" ?>

<!--
	Administration area for the React view UI. The tab bar's content is registered at the
	ViewContributionService under the "admin" extension point (see tl-layout-view.conf.config.xml). A
	depending module adds a section by registering an <extension id="admin"> of its own, so the tab
	bar is extended - and its sections repositioned - purely through configuration merge, without this
	view's module depending on the contributor.
-->
<view>
	<extension-point id="admin"/>
</view>