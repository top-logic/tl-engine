<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="model"/>
	</channels>
	<window width="500px">
		<title>
			<en>Reset Password</en>
			<de>Passwort zurücksetzen</de>
		</title>
		<form
			initial-edit-mode="true"
			input="model"
			mode-switch="false"
		>
			<field
				attribute="account"
				readonly="true"
			/>
			<field attribute="password"/>
			<commands>
				<generic-command
					image="css:bi bi-check-lg"
					placement="BUTTON_BAR"
				>
					<label>
						<en>Set password</en>
						<de>Passwort setzen</de>
					</label>
					<store-form-state/>
					<with-transaction>
						<set-password/>
					</with-transaction>
					<close-dialog/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand"
					image="css:bi bi-x-lg"
				>
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>