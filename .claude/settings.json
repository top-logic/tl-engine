{                                                                                                                                                                                                                                                  
  "permissions": {                                                                                                                                                                                                                                 
    "allow": [                                                                                                                                                                                                                                     
      "Bash(npm *)",                                                                                                                                                                                                                               
      "Bash(mvn *)"
    ]                                                                                                                                                                                                                                              
  },                                                      
  "sandbox": {                                                                                                                                                                                                                                     
    "enabled": true,                                                                                                                                                                                                                               
    "autoAllowBashIfSandboxed": true,                                                                                                                                                                                                              
    "filesystem": {                                                                                                                                                                                                                                
      "allowWrite": [
        "~/.npm",
        "/tmp"
      ]
    },                                                                                                                                                                                                                                     
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "api-free.deepl.com",
        "nodejs.org",
        "dev.top-logic.com",
        "repo.maven.apache.org"
      ]
    }                                                                                                                                                                                                                                            
  }
}

