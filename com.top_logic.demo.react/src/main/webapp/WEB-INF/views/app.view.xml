<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<!-- The currently active session user, for display in the app bar. -->
		<derived-channel name="currentPerson"
			expr="currentUser()"
		/>
	</channels>
	<app-shell>
		<content>
			<sidebar
				active-item="attributes"
				drawer-open-slot-name="appbar-leading"
			>
				<items>
					<nav-item id="attributes"
						icon="css:bi bi-card-list"
					>
						<view-ref view="attributes.view.xml"/>
						<label>
							<en>Attributes</en>
							<de>Attribute</de>
						</label>
					</nav-item>
					<nav-item id="tickets"
						icon="css:bi bi-chat-left-text"
					>
						<view-ref view="tickets.view.xml"/>
						<label>
							<en>Object list</en>
							<de>Objektliste</de>
						</label>
					</nav-item>
					<nav-item id="charts"
						icon="css:bi bi-bar-chart-line"
					>
						<view-ref view="demo/chart-demo.view.xml"/>
						<label>
							<en>Chart Demo</en>
							<de>Diagramm-Demo</de>
						</label>
					</nav-item>
					<nav-item id="flow-diagram"
						icon="css:bi bi-diagram-3"
					>
						<view-ref view="demo/flow-diagram-demo.view.xml"/>
						<label>
							<en>Flow Diagram</en>
							<de>Flow-Diagramm</de>
						</label>
					</nav-item>
					<nav-item id="gantt-demo"
						icon="css:bi bi-bar-chart-steps"
					>
						<view-ref view="demo/gantt-demo.view.xml"/>
						<label>
							<en>Gantt Demo</en>
							<de>Gantt-Demo</de>
						</label>
					</nav-item>
					<nav-item id="pdf"
						icon="css:bi bi-file-earmark-pdf"
					>
						<view-ref view="demo/pdf-demo.view.xml"/>
						<label>
							<en>PDF Viewer</en>
							<de>PDF-Viewer</de>
						</label>
					</nav-item>
					<nav-item id="config-editor"
						icon="css:bi bi-sliders"
					>
						<view-ref view="demo/config-editor-demo.view.xml"/>
						<label>
							<en>Config Editor</en>
							<de>Konfigurationseditor</de>
						</label>
					</nav-item>
					<nav-item id="tlscript"
						icon="css:bi bi-code-square"
					>
						<view-ref view="demo/tlscript-editor-demo.view.xml"/>
						<label>
							<en>TL-Script Editor</en>
							<de>TL-Script-Editor</de>
						</label>
					</nav-item>
					<nav-item id="constraints"
						icon="css:bi bi-check-circle"
					>
						<view-ref view="demo/constraint-test.view.xml"/>
						<label>
							<en>Constraint Test</en>
							<de>Constraint-Test</de>
						</label>
					</nav-item>
					<nav-item id="tiles-demo"
						icon="css:bi bi-layers"
					>
						<view-ref view="demo/tiles-demo.view.xml"/>
						<label>
							<en>Tiles Demo</en>
							<de>Tiles-Demo</de>
						</label>
					</nav-item>
					<nav-item id="tiles-multi-demo"
						icon="css:bi bi-columns-gap"
					>
						<view-ref view="demo/tiles-multi-demo.view.xml"/>
						<label>
							<en>Tiles Multi-Tab Demo</en>
							<de>Tiles Mehr-Tab-Demo</de>
						</label>
					</nav-item>
					<nav-item id="responsive-md-demo"
						icon="css:bi bi-layout-sidebar-inset"
					>
						<view-ref view="demo/responsive-md-demo.view.xml"/>
						<label>
							<en>Responsive Master-Detail Demo</en>
							<de>Responsive Master-Detail-Demo</de>
						</label>
					</nav-item>
					<nav-item id="errors"
						icon="css:bi bi-exclamation-triangle"
					>
						<view-ref view="demo/error-handling-demo.view.xml"/>
						<label>
							<en>Error Handling</en>
							<de>Fehlerbehandlung</de>
						</label>
					</nav-item>
					<separator/>
					<nav-item id="administration"
						icon="css:bi bi-shield-lock"
						route="none"
					>
						<access-control scope="administration"/>
						<view-ref view="admin/admin.view.xml"/>
						<label>
							<en>Administration</en>
							<de>Administration</de>
						</label>
					</nav-item>
				</items>
			</sidebar>
		</content>
		<header>
			<app-bar variant="flat">
				<commands>
					<open-designer
						image="css:bi bi-easel"
						placement="TOOLBAR"
					>
						<label>
							<en>Designer</en>
							<de>Designer</de>
						</label>
						<tooltip>
							<en>Open the view designer to edit the current page.</en>
							<de>Öffnet den View-Designer zur Bearbeitung der aktuellen Seite.</de>
						</tooltip>
					</open-designer>

					<!--
						Pops out the script-recorder side-window: a generic open-window command configured
						with the recorder view.
					-->
					<open-window
						height="320"
						image="css:bi bi-record-circle"
						placement="TOOLBAR"
						singleton-key="script-recorder"
						view="script-recorder.view.xml"
						width="420"
					>
						<title>
							<en>Script Recorder</en>
							<de>Skript-Rekorder</de>
						</title>
						<label>
							<en>Record</en>
							<de>Aufzeichnen</de>
						</label>
						<tooltip>
							<en>Open the script recorder to capture interactions as a replayable script.</en>
							<de>Öffnet den Skript-Rekorder, um Interaktionen als abspielbares Skript aufzuzeichnen.</de>
						</tooltip>
						<executability>
							<authenticated-only/>
						</executability>
					</open-window>

					<!-- Login: shown only for the anonymous user; opens the login dialog. -->
					<generic-command
						image="css:bi bi-box-arrow-in-right"
						placement="TOOLBAR"
					>
						<label>
							<en>Login</en>
							<de>Anmeldung</de>
						</label>
						<executability>
							<anonymous-only/>
						</executability>
						<execute-script function="x -> new(`tl.login:Credentials`, transient: true)"/>
						<open-dialog
							bind-input-to="model"
							close-on-backdrop="false"
							dialog-view="login.view.xml"
						/>
					</generic-command>

					<!-- Logout: shown only for an authenticated user. -->
					<logout-command
						image="css:bi bi-box-arrow-right"
						placement="TOOLBAR"
					>
						<label>
							<en>Logout</en>
							<de>Abmeldung</de>
						</label>
						<executability>
							<authenticated-only/>
						</executability>
					</logout-command>
				</commands>
				<title>
					<en>TopLogic React Demo</en>
					<de>TopLogic React Demo</de>
				</title>
				<leading>
					<!--
						Mobile drawer-toggle target. The sidebar above is configured with
						drawer-open-slot-name="appbar-leading", which makes it contribute a
						hamburger button into this slot via the slot-content registry; CSS makes
						it visible only at small viewports. The two names must match.
					-->
					<slot name="appbar-leading"/>
				</leading>
				<children>
					<text
						css-class="tlAppBarUser"
						input="currentPerson"
						overflow="ellipsis"
					/>
				</children>
			</app-bar>
		</header>
	</app-shell>
</view>