<?xml version="1.0" encoding="iso-8859-1" ?>

<!--
	Multi-tab tile drill-down demo.

	Two tabs, each hosting its own independent tile-stack with its own navPath channel and its
	own breadcrumb. Only one tab's content is mounted at a time, so only one breadcrumb is in
	the slot registry at a time; the app bar's <slot name="secondary"/> shows the active tab's
	breadcrumb. Switching tabs implicitly switches the visible breadcrumb - no app-level
	multiplexer needed.

	The two tabs use the same overview / detail views, but their navigation state is
	independent: drilling into one tab does not affect the other.
-->
<view>
	<tab-bar active-tab="left">
		<tabs>
			<tab id="left">
				<label>
					<en>Workspace A</en>
					<de>Arbeitsbereich A</de>
				</label>
				<view>
					<channels>
						<channel name="navPath"/>
					</channels>

					<slot-content to="secondary">
						<tile-breadcrumb path="navPath">
							<home-label>
								<en>Workspace A &#x2013; Accounts</en>
								<de>Arbeitsbereich A &#x2013; Konten</de>
							</home-label>
						</tile-breadcrumb>
					</slot-content>

					<tile-stack
						path="navPath"
						initial="demo/tiles-demo/overview.view.xml"
					/>
				</view>
			</tab>
			<tab id="right">
				<label>
					<en>Workspace B</en>
					<de>Arbeitsbereich B</de>
				</label>
				<view>
					<channels>
						<channel name="navPath"/>
					</channels>

					<slot-content to="secondary">
						<tile-breadcrumb path="navPath">
							<home-label>
								<en>Workspace B &#x2013; Accounts</en>
								<de>Arbeitsbereich B &#x2013; Konten</de>
							</home-label>
						</tile-breadcrumb>
					</slot-content>

					<tile-stack
						path="navPath"
						initial="demo/tiles-demo/overview.view.xml"
					/>
				</view>
			</tab>
		</tabs>
	</tab-bar>
</view>
