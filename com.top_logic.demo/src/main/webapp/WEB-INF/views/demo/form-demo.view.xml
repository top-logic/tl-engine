<?xml version="1.0" encoding="iso-8859-1" ?>

<view>
	<channels>
		<channel name="selectedPerson"/>
		<derived-channel name="selectedContact"
			expr="person -> $person.get(`tl.accounts:Person#contact`)"
			inputs="selectedPerson"
		/>
		<derived-channel name="personName"
			inputs="selectedPerson"
			expr="person -> if($person != null, $person.get(`tl.accounts:Person#name`), null)"
			reverse="name -> if($name != null, singleElement(filter(all(`tl.accounts:Person`), p -> $p.get(`tl.accounts:Person#name`) == $name)), null)"
		/>
	</channels>
	<param-bindings>
		<bind channel="personName" route-param="personName"/>
	</param-bindings>
	<split-panel
		orientation="horizontal"
		resizable="true"
	>
		<panes>
			<pane
				min-size="200"
				size="40"
				unit="%"
			>
				<panel>
					<title>
						<en>Accounts</en>
						<de>Konten</de>
					</title>
					<commands>
						<command class="com.top_logic.layout.view.command.OpenDialogCommand"
							placement="TOOLBAR"
							dialog-view="demo/edit-person-dialog.view.xml"
							input="selectedPerson"
							bind-input-to="model"
						>
							<label>
								<en>Edit</en>
								<de>Bearbeiten</de>
							</label>
						</command>
						<!--
							Expires the selected account's password, forcing the React login's
							change-password step on that account's next login. Exercises the
							password-expiry login flow (Ticket #29108, phase 2).
						-->
						<generic-command placement="TOOLBAR"
							input="selectedPerson"
						>
							<label>
								<en>Expire password</en>
								<de>Passwort ablaufen lassen</de>
							</label>
							<executability>
								<null-input-disabled/>
							</executability>
							<expire-password/>
						</generic-command>
						<!--
							Marks the selected account as MFA-required with no secret, forcing the
							React login's enrollment step on that account's next login. Exercises the
							MFA-enrollment login flow (Ticket #29108, phase 2b).
						-->
						<generic-command placement="TOOLBAR"
							input="selectedPerson"
						>
							<label>
								<en>Require MFA (enroll)</en>
								<de>MFA verlangen (Einrichtung)</de>
							</label>
							<executability>
								<null-input-disabled/>
							</executability>
							<enable-mfa/>
						</generic-command>
						<!--
							Stores a fixed, known TOTP secret on the selected account, so the React
							login's OTP-verification step can be exercised with a computed code
							(Ticket #29108, phase 2b).
						-->
						<generic-command placement="TOOLBAR"
							input="selectedPerson"
						>
							<label>
								<en>Set MFA secret (OTP)</en>
								<de>MFA-Schl&#252;ssel setzen (OTP)</de>
							</label>
							<executability>
								<null-input-disabled/>
							</executability>
							<enable-mfa secret="JBSWY3DPEHPK3PXP"/>
						</generic-command>
					</commands>
					<table
						selection="selectedPerson"
						types="tl.accounts:Person"
					>
						<rows>all(`tl.accounts:Person`)</rows>
					</table>
				</panel>
			</pane>
			<pane
				size="60"
				unit="%"
			>
				<panel>
					<title>
						<en>Contact Details</en>
						<de>Kontaktdetails</de>
					</title>
					<form input="selectedContact">
						<field attribute="firstname"/>
						<field attribute="name"/>
						<field attribute="phone"/>
						<field attribute="email"/>
					</form>
				</panel>
			</pane>
		</panes>
	</split-panel>
</view>
