<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<!-- Transient PasswordReset model (code + new password) bound to the form. -->
		<channel name="model"/>
		<!-- The account whose password is being reset (set by RequestPasswordResetAction). -->
		<channel name="account"/>
		<!-- The expected verification code (set by RequestPasswordResetAction). -->
		<channel name="expectedCode"/>
		<!-- Epoch-millis creation time of the code, for the validity check. -->
		<channel name="createdAt"/>
	</channels>
	<window resizable="false"
			width="400px">
		<title>
			<en>Set a new password</en>
			<de>Neues Passwort setzen</de>
		</title>
		<form input="model"
			initial-edit-mode="true"
			mode-switch="false"
		>
			<text>
				<label>
					<en>Enter the verification code from the email, then choose a new password.</en>
					<de>Geben Sie den Best&#228;tigungscode aus der E-Mail ein und w&#228;hlen Sie ein neues Passwort.</de>
				</label>
			</text>
			<field attribute="code"/>
			<field attribute="newPassword"/>
			<field attribute="newPasswordConfirm"/>
			<commands>
				<generic-command placement="BUTTON_BAR">
					<label>
						<en>Reset password</en>
						<de>Passwort zur&#252;cksetzen</de>
					</label>
					<store-form-state/>
					<apply-password-reset/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand">
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>
