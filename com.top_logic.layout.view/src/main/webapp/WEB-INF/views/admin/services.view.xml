<?xml version="1.0" encoding="utf-8" ?>

<!--
	Services management: list the application services (runtime modules) and start / stop / restart the
	selected one. The ServiceTable shows a live snapshot when opened and rebuilds from the services
	channel after a command. It writes the selected module to the selection channel and its running
	status ('ACTIVE' / 'INACTIVE') to the state channel; the commands gate on that state via the
	reusable <visible-if> rule so Start (while stopped) and Stop / Restart (while running) are mutually
	exclusive. Each command runs the ServiceLifecycleAction (which reads the module from the selection
	channel), writes the refreshed service list to the services channel, then writes the new state. A
	titled <panel> is used (not the chrome-less <full-page>) because the view carries toolbar commands.
-->
<view>
	<channels>
		<channel name="services"/>
		<channel name="selection"/>
		<channel name="state"/>
	</channels>
	<panel fill="true">
		<title>
			<en>Services</en>
			<de>Dienste</de>
		</title>
		<commands>
			<generic-command
				image="css:bi bi-play"
				input="state"
				placement="TOOLBAR"
			>
				<label>
					<en>Start</en>
					<de>Starten</de>
				</label>
				<executability>
					<visible-if expr="state -> $state == 'INACTIVE'"/>
				</executability>
				<action class="com.top_logic.layout.view.admin.system.ServiceLifecycleAction"
					mode="START"
					selection="selection"
				/>
				<write-channel name="services"/>
				<execute-script function="'ACTIVE'"/>
				<write-channel name="state"/>
			</generic-command>
			<generic-command
				image="css:bi bi-stop"
				input="state"
				placement="TOOLBAR"
			>
				<label>
					<en>Stop</en>
					<de>Stoppen</de>
				</label>
				<executability>
					<visible-if expr="state -> $state == 'ACTIVE'"/>
				</executability>
				<action class="com.top_logic.layout.view.admin.system.ServiceLifecycleAction"
					mode="STOP"
					selection="selection"
				/>
				<write-channel name="services"/>
				<execute-script function="'INACTIVE'"/>
				<write-channel name="state"/>
			</generic-command>
			<generic-command
				image="css:bi bi-arrow-repeat"
				input="state"
				placement="TOOLBAR"
			>
				<label>
					<en>Restart</en>
					<de>Neustart</de>
				</label>
				<executability>
					<visible-if expr="state -> $state == 'ACTIVE'"/>
				</executability>
				<action class="com.top_logic.layout.view.admin.system.ServiceLifecycleAction"
					mode="RESTART"
					selection="selection"
				/>
				<write-channel name="services"/>
				<execute-script function="'ACTIVE'"/>
				<write-channel name="state"/>
			</generic-command>
			<generic-command
				image="css:bi bi-arrow-clockwise"
				placement="TOOLBAR"
			>
				<label>
					<en>Refresh</en>
					<de>Aktualisieren</de>
				</label>
				<action class="com.top_logic.layout.view.admin.system.ServiceLifecycleAction"
					mode="REFRESH"
				/>
				<write-channel name="services"/>
			</generic-command>
		</commands>
		<child class="com.top_logic.layout.view.admin.system.ServiceTable"
			input="services"
			selection="selection"
			state="state"
		/>
	</panel>
</view>