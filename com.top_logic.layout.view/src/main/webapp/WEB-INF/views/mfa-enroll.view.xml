<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<!-- Transient OtpEntry model bound to the form. -->
		<channel name="model"/>
		<!-- The account enabling MFA (set by LoginAction). -->
		<channel name="account"/>
		<!-- The freshly generated TOTP secret, persisted only once a valid code confirms it. -->
		<channel name="secret"/>
		<!-- The QR-code PNG encoding the otpauth:// provisioning URI (set by LoginAction). -->
		<channel name="qr"/>
	</channels>
	<window resizable="false"
			width="420px">
		<title>
			<en>Set up two-factor authentication</en>
			<de>Zwei-Faktor-Authentifizierung einrichten</de>
		</title>
		<form input="model"
			initial-edit-mode="true"
			mode-switch="false"
		>
			<text>
				<label>
					<en>Scan this QR code with your authenticator app, then enter the generated code to confirm.</en>
					<de>Scannen Sie diesen QR-Code mit Ihrer Authenticator-App und geben Sie zur Best&#228;tigung den erzeugten Code ein.</de>
				</label>
			</text>
			<image input="qr"/>
			<field attribute="code"/>
			<commands>
				<generic-command placement="BUTTON_BAR">
					<label>
						<en>Confirm</en>
						<de>Best&#228;tigen</de>
					</label>
					<store-form-state/>
					<verify-otp persist="true"/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand">
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>
