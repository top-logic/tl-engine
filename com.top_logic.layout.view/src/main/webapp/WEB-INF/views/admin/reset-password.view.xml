<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="model"/>
	</channels>
	<window
		width="500px"
	>
		<title>
			<en>Reset Password</en>
			<de>Passwort zur&#xFC;cksetzen</de>
		</title>
		<form input="model"
			initial-edit-mode="true"
			mode-switch="false"
		>
			<field attribute="account"
				readonly="true"
			/>
			<field attribute="password"/>
			<commands>
				<generic-command placement="TOOLBAR">
					<label>
						<en>Set password</en>
						<de>Passwort setzen</de>
					</label>
					<store-form-state/>
					<with-transaction>
						<set-password/>
					</with-transaction>
					<close-dialog/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand">
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>
