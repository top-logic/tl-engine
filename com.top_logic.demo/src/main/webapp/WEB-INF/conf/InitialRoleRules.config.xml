<?xml version="1.0" encoding="utf-8" ?>

<application>
	<services>
		<config service-class="com.top_logic.tool.boundsec.manager.AccessManager">
			<instance>
				<role-rules>
					<rules>
						<rule
							inherit="true"
							meta-element="tl.accounts:WithOwner"
							role="SecurityStructure.OwnerRole"
						>
							<path>
								<step attribute="tl.accounts:WithOwner#owner"/>
							</path>
						</rule>

						<rule
							inherit="true"
							meta-element="DemoSecurity:DemoSecurity.A"
							role="DemoSecurity.Role1"
						>
							<path>
								<step attribute="DemoSecurity:DemoSecurity.A#singlePersonContact"/>
							</path>
						</rule>

						<rule
							inherit="true"
							meta-element="DemoSecurity:DemoSecurity.A"
							role="DemoSecurity.Role2"
						>
							<path>
								<step attribute="DemoSecurity:DemoSecurity.A#personContactList"/>
							</path>
						</rule>

						<inheritance-rule
							inherit="true"
							meta-element="DemoSecurity:DemoSecurity.A"
							role="DemoSecurity.SecurityAdministrator"
						>
							<path>
								<step
									attribute="DemoSecurity:DemoSecurityElementContainer#children"
									inverse="true"
								/>
							</path>
						</inheritance-rule>

						<inheritance-rule
							inherit="true"
							meta-element="DemoSecurity:DemoSecurity.B"
							role="DemoSecurity.SecurityAdministratorB"
							source-role="DemoSecurity.SecurityAdministrator"
						>
							<singleton module="DemoSecurity"/>
						</inheritance-rule>

						<inheritance-rule
							inherit="true"
							meta-element="DemoSecurity:DemoSecurity.All"
							role="selection"
							source-role="DemoSecurity.Role1,DemoSecurity.Role2,DemoSecurity.SecurityAdministrator,DemoSecurity.SecurityAdministratorB,DemoSecurity.User"
						/>

						<inheritance-rule
							inherit="true"
							meta-element="DemoSecurity:DemoSecurity.All"
							role="navigation"
							source-role="selection"
						/>

						<inheritance-rule
							inherit="true"
							meta-element="DemoSecurity:DemoSecurityElementContainer"
							role="navigation"
						>
							<path>
								<step attribute="DemoSecurity:DemoSecurityElementContainer#children"/>
							</path>
						</inheritance-rule>

						<inheritance-rule
							inherit="true"
							meta-element="DemoTypes:DemoTypes.All"
							role="navigation"
							source-role="selection"
						/>

						<inheritance-rule
							inherit="true"
							meta-element="DemoTypes:DemoTypesContainer"
							role="navigation"
						>
							<path>
								<step attribute="DemoTypes:DemoTypesContainer#children"/>
							</path>
						</inheritance-rule>

						<inheritance-rule
							inherit="true"
							meta-element="DemoTypes:DemoTypes.All"
							role="DemoTypes.Administrator,DemoTypes.StringAdministrator,DemoTypes.BooleanAdministrator,DemoTypes.DateAdministrator,DemoTypes.Responsible"
						>
							<path>
								<step
									attribute="DemoTypes:DemoTypesContainer#children"
									inverse="true"
								/>
							</path>
						</inheritance-rule>

						<inheritance-rule
							inherit="true"
							meta-element="DemoTypes:DemoTypes.All"
							role="selection"
							source-role="DemoTypes.Administrator,DemoTypes.Responsible,DemoTypes.BAdministrator,DemoTypes.BooleanAdministrator,DemoTypes.DateAdministrator,DemoTypes.StringAdministrator"
						/>

						<rule
							inherit="true"
							meta-element="DemoTypes:DemoTypes.A"
							role="DemoTypes.Responsible"
						>
							<path>
								<step attribute="DemoTypes:DemoTypes.A#responsible"/>
							</path>
						</rule>
						<rule
							inherit="true"
							meta-element="DemoTypes:DemoTypes.A"
							role="DemoTypes.Responsible"
						>
							<path>
								<step attribute="DemoTypes:DemoTypes.A#responsibleContact"/>
								<step
									attribute="tl.accounts:Person#contact"
									inverse="true"
								/>
							</path>
						</rule>

						<inheritance-rule
							inherit="true"
							meta-element="DemoTypes:DemoTypes.B"
							role="DemoTypes.BAdministrator"
						>
							<singleton module="DemoTypes"/>
						</inheritance-rule>

						<rule
							inherit="true"
							meta-element="DemoPlain:DemoPlain.All"
							role="DemoTypes.Administrator"
						>
							<group-with-name name="demoTypeAdministrators"/>
						</rule>
						<singleton-rule
							role="DemoTypes.Administrator"
							target="DemoTypes#ROOT"
						>
							<group-with-name name="demoTypeAdministrators"/>
						</singleton-rule>

						<singleton-rule
							role="DemoTypes.BAdministrator"
							target="DemoTypes#ROOT"
						>
							<group-with-name name="demoTypeBAdministrators"/>
						</singleton-rule>
					</rules>
				</role-rules>
			</instance>
		</config>
	</services>
</application>