<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<!-- Transient ForgotPassword model (username) bound to the form. -->
		<channel name="model"/>
	</channels>
	<window width="400px">
		<title>
			<en>Reset password</en>
			<de>Passwort zur&#252;cksetzen</de>
		</title>
		<form input="model"
			initial-edit-mode="true"
			mode-switch="false"
		>
			<text>
				<label>
					<en>Enter your user name. If an account exists, we will email a verification code you can use to set a new password.</en>
					<de>Geben Sie Ihren Benutzernamen ein. Falls ein Konto existiert, senden wir per E-Mail einen Best&#228;tigungscode, mit dem Sie ein neues Passwort setzen k&#246;nnen.</de>
				</label>
			</text>
			<field attribute="username"/>
			<commands>
				<generic-command placement="TOOLBAR">
					<label>
						<en>Send code</en>
						<de>Code senden</de>
					</label>
					<store-form-state/>
					<request-password-reset/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand">
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>
