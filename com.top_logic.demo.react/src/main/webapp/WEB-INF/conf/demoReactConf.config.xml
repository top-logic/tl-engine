<?xml version="1.0" encoding="utf-8"?>

<application xmlns:config="http://www.top-logic.com/ns/config/6.0">
	<services>
		<config service-class="com.top_logic.basic.util.ResourcesModule">
			<instance>
				<bundles>
					<bundle name="model.demo.react.messages"/>
				</bundles>
			</instance>
		</config>
		<config service-class="com.top_logic.util.model.ModelService">
			<instance>
				<declarations>
					<declaration file="/WEB-INF/model/demo.react.model.xml"/>
				</declarations>
			</instance>
		</config>

		<!--
			Demonstrates that view contributions generalize beyond tab bars: this contributes a
			navigation item into the app-shell sidebar's "app.sidebar" extension point (declared in
			app.view.xml), the same way tl-model-search-react contributes the Development tab into
			the admin tab bar.
		-->
		<config service-class="com.top_logic.layout.view.contribution.ViewContributionService">
			<instance class="com.top_logic.layout.view.contribution.ViewContributionService">
				<contributions>
					<contribution id="contributed-section"
						target="app.sidebar"
						view="sidebar-contribution.view.xml"
						icon="css:bi bi-puzzle"
						rank="1000"
					>
						<label>
							<en>Contributed</en>
							<de>Beigesteuert</de>
						</label>
					</contribution>
				</contributions>
			</instance>
		</config>
	</services>

	<configs>
		<!--
			This is a React-only application: its entry point is the React view shell at /view/.
			The framework's start page is a singleton setting that the legacy core defaults to the
			layout servlet; the application authoritatively declares its own entry here.
		-->
		<config config:interface="com.top_logic.base.accesscontrol.ApplicationPages$Config">
			<startPage>/view/</startPage>
		</config>
	</configs>
</application>
