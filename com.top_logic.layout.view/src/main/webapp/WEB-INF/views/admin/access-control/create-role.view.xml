<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="model"/>
		<channel name="selection"/>
	</channels>
	<window width="500px">
		<title>
			<en>New Role</en>
			<de>Neue Rolle</de>
		</title>
		<form
			initial-edit-mode="true"
			input="model"
			mode-switch="false"
		>
			<field attribute="name"/>
			<field attribute="isSystem"/>
			<field attribute="description"/>
			<commands>
				<generic-command
					image="css:bi bi-check-lg"
					placement="BUTTON_BAR"
				>
					<label>
						<en>Create</en>
						<de>Erstellen</de>
					</label>
					<store-form-state/>
					<with-transaction>
						<execute-script function="obj -> $obj.copy(transient: false)"/>
					</with-transaction>
					<write-channel name="selection"/>
					<close-dialog/>
				</generic-command>
			</commands>
		</form>
		<actions>
			<button>
				<action class="com.top_logic.layout.view.command.CancelDialogCommand"
					image="css:bi bi-x-lg"
				>
					<label>
						<en>Cancel</en>
						<de>Abbrechen</de>
					</label>
				</action>
			</button>
		</actions>
	</window>
</view>