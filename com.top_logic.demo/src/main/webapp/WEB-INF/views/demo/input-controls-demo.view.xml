<?xml version="1.0" encoding="utf-8" ?>

<view>
	<channels>
		<channel name="selectedObject"/>
	</channels>
	<split-panel
		orientation="horizontal"
		resizable="true"
	>
		<panes>
			<pane
				min-size="200"
				size="30"
				unit="%"
			>
				<panel title="Demo Types">
					<tree selection="selectedObject">
						<root>`DemoTypes#ROOT`</root>
						<children>node -&gt; $node.get(`tl.element:StructuredElementContainer#children`)</children>
					</tree>
				</panel>
			</pane>
			<pane
				size="70"
				unit="%"
			>
				<panel title="Object Details">
					<form input="selectedObject">
						<field attribute="name"/>
						<field attribute="color"/>
						<field attribute="string"/>
						<field attribute="boolean"/>
						<field attribute="date"/>
						<field attribute="float"/>
						<field attribute="icon"/>
					</form>
				</panel>
			</pane>
		</panes>
	</split-panel>
</view>