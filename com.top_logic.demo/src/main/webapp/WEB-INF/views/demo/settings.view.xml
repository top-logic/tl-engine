<?xml version="1.0" encoding="iso-8859-1" ?>

<view>
	<inset>
	<card
		variant="elevated"
	>
		<title>
			<en>Settings</en>
			<de>Einstellungen</de>
		</title>
		<button>
			<action class="com.top_logic.demo.view.command.DemoCommand">
				<label>
					<en>Save Settings</en>
					<de>Einstellungen speichern</de>
				</label>
				<!--
					Command-level access control: executable only for users granted the "Write"
					command group on the enclosing nav-item's "demo-restricted" scope (no explicit
					scope, so it defaults to the enclosing unit's scope). The technical super user
					(root) bypasses the check. Enforced both on the button and at server dispatch.
				-->
				<executability>
					<security group="Write"/>
				</executability>
			</action>
		</button>
	</card>
	<card
		variant="elevated"
	>
		<title>
			<en>Theme</en>
			<de>Design</de>
		</title>
		<button>
			<action class="com.top_logic.layout.view.command.SetThemeCommand"
				theme="default"
			>
				<label>
					<en>Light</en>
					<de>Hell</de>
				</label>
			</action>
		</button>
		<button>
			<action class="com.top_logic.layout.view.command.SetThemeCommand"
				theme="dark"
			>
				<label>
					<en>Dark</en>
					<de>Dunkel</de>
				</label>
			</action>
		</button>
	</card>
	</inset>
</view>