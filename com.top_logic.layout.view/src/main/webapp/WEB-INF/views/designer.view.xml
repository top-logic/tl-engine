<?xml version="1.0" encoding="utf-8" ?>
<view xmlns="http://www.top-logic.com/ns/view/1.0">
	<channels>
		<channel name="designTree"/>
		<channel name="selectedNode"/>
	</channels>

	<panel>
		<title>
			<en>View Designer</en>
			<de>View-Designer</de>
		</title>
		<commands>
			<save-design design-tree="designTree" placement="TOOLBAR">
				<label>
					<en>Apply</en>
					<de>Anwenden</de>
				</label>
			</save-design>
			<revert-design design-tree="designTree" selection="selectedNode" placement="TOOLBAR">
				<label>
					<en>Revert</en>
					<de>Verwerfen</de>
				</label>
			</revert-design>
			<select-view design-tree="designTree" selection="selectedNode" placement="TOOLBAR">
				<label>
					<en>Select view</en>
					<de>Sicht auswählen</de>
				</label>
				<tooltip>
					<en>Pick a view in the main window to select it here.</en>
					<de>Eine Sicht im Hauptfenster anklicken, um sie hier auszuwählen.</de>
				</tooltip>
			</select-view>
		</commands>

		<split-panel orientation="horizontal" resizable="true">
			<panes>
				<pane size="40" unit="%" min-size="200">
					<design-tree input="designTree" selection="selectedNode"/>
				</pane>
				<pane size="60" unit="%">
					<config-editor input="selectedNode"/>
				</pane>
			</panes>
		</split-panel>
	</panel>
</view>
