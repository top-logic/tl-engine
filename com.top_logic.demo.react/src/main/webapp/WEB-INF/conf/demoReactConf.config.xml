<?xml version="1.0" encoding="utf-8"?>

<application xmlns:config="http://www.top-logic.com/ns/config/6.0">
	<services>
		<config service-class="com.top_logic.basic.util.ResourcesModule">
			<instance>
				<bundles>
					<bundle name="model.demo.react.messages"/>
				</bundles>
			</instance>
		</config>
		<config service-class="com.top_logic.util.model.ModelService">
			<instance>
				<declarations>
					<declaration file="/WEB-INF/model/demo.react.model.xml"/>
				</declarations>
			</instance>
		</config>
	</services>

	<configs>
		<!--
			This is a React-only application: its entry point is the React view shell at /view/.
			The framework's start page is a singleton setting that the legacy core defaults to the
			layout servlet; the application authoritatively declares its own entry here.
		-->
		<config config:interface="com.top_logic.base.accesscontrol.ApplicationPages$Config">
			<startPage>/view/</startPage>
		</config>
	</configs>
</application>
