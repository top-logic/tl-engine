<?xml version="1.0" encoding="utf-8" ?>
<application xmlns:config="http://www.top-logic.com/ns/config/6.0">
	<services>
		<config service-class="com.top_logic.basic.module.ModuleSystem">
			<instance class="com.top_logic.basic.module.ModuleSystem">
				<modules>
					<module key="com.top_logic.layout.view.form.FieldControlService$Module"
						value="true"
					/>
					<module key="com.top_logic.layout.view.table.ColumnProviderService$Module"
						value="true"
					/>
					<module key="com.top_logic.layout.view.security.SecurityScopeService$Module"
						value="true"
					/>
					<module key="com.top_logic.layout.view.contribution.ViewContributionService$Module"
						value="true"
					/>
				</modules>
			</instance>
		</config>

		<!--
			Registry of cross-module view contributions. A view declares a named extension point
			(e.g. <tab-bar extension-id="admin.sections">); depending modules append <contribution>
			entries here that target it, so a view can be extended without its module depending on
			the contributors. The base configuration is empty; see the 29108-view-contributions spec.
		-->
		<config service-class="com.top_logic.layout.view.contribution.ViewContributionService">
			<instance class="com.top_logic.layout.view.contribution.ViewContributionService">
				<!--
					Base content of the "tl.view.playground" extension point, embedded by
					views/playground/extension-point-demo.view.xml through <extension-point>. A
					depending module refines this tab bar (adding, positioning or overriding tabs) by
					registering an <extension id="tl.view.playground"> of its own; the entries merge by
					id, so the depending module needs no code and this module no knowledge of it.
				-->
				<extensions>
					<extension id="tl.view.playground">
						<tab-bar active-tab="overview">
							<tabs>
								<tab id="overview">
									<label>
										<en>Overview</en>
										<de>Übersicht</de>
									</label>
									<panel>
										<title>
											<en>Framework tab</en>
											<de>Framework-Tab</de>
										</title>
										<text>
											<label>
												<en>This tab is part of the extension point's base content, registered by the framework module (tl-layout-view).</en>
												<de>Dieser Tab gehört zum Basisinhalt des Erweiterungspunkts, registriert vom Framework-Modul (tl-layout-view).</de>
											</label>
										</text>
									</panel>
								</tab>
								<tab id="settings">
									<label>
										<en>Settings</en>
										<de>Einstellungen</de>
									</label>
									<panel>
										<title>
											<en>Framework tab</en>
											<de>Framework-Tab</de>
										</title>
										<text>
											<label>
												<en>Another framework-provided tab. A depending module can insert its own tab before this one without editing this configuration.</en>
												<de>Ein weiterer vom Framework bereitgestellter Tab. Ein abhängiges Modul kann seinen eigenen Tab davor einfügen, ohne diese Konfiguration zu bearbeiten.</de>
											</label>
										</text>
									</panel>
								</tab>
							</tabs>
						</tab-bar>
					</extension>

					<!--
						Base content of the "admin" extension point, embedded by
						views/admin/admin.view.xml. Depending modules add sections (Development, Model)
						by registering an <extension id="admin"> that merges a <tab> into this tab bar;
						see tl-model-search-react and tl-dev-tools. Tabs are written directly (no <tabs>
						wrapper) since the tabs property is the tab bar's default container.
					-->
					<extension id="admin">
						<tab-bar active-tab="access-control">
							<tab id="access-control">
								<label>
									<en>Access control</en>
									<de>Zugriffskontrolle</de>
								</label>
								<tab-bar active-tab="accounts">
									<tab id="accounts">
										<label>
											<en>Accounts</en>
											<de>Konten</de>
										</label>
										<view-ref view="admin/access-control/accounts.view.xml"/>
									</tab>
									<tab id="groups">
										<label>
											<en>Groups</en>
											<de>Gruppen</de>
										</label>
										<view-ref view="admin/access-control/groups.view.xml"/>
									</tab>
									<tab id="roles">
										<label>
											<en>Roles</en>
											<de>Rollen</de>
										</label>
										<view-ref view="admin/access-control/roles.view.xml"/>
									</tab>
									<tab id="permissions">
										<label>
											<en>Permissions</en>
											<de>Berechtigungen</de>
										</label>
										<view-ref view="admin/access-control/permissions.view.xml"/>
									</tab>
								</tab-bar>
							</tab>
							<tab id="monitoring">
								<label>
									<en>Monitoring</en>
									<de>Überwachung</de>
								</label>
								<tab-bar active-tab="system-environment">
									<tab id="system-environment">
										<label>
											<en>System environment</en>
											<de>Systemumgebung</de>
										</label>
										<view-ref view="admin/monitoring/system-environment.view.xml"/>
									</tab>
									<tab id="application-monitor">
										<label>
											<en>Application</en>
											<de>Anwendung</de>
										</label>
										<view-ref view="admin/monitoring/application-monitor.view.xml"/>
									</tab>
									<tab id="thread-monitor">
										<label>
											<en>Threads</en>
											<de>Threads</de>
										</label>
										<view-ref view="admin/monitoring/thread-monitor.view.xml"/>
									</tab>
									<tab id="user-sessions">
										<label>
											<en>Sessions</en>
											<de>Sitzungen</de>
										</label>
										<view-ref view="admin/monitoring/user-sessions.view.xml"/>
									</tab>
									<tab id="failed-logins">
										<label>
											<en>Failed logins</en>
											<de>Fehlgeschlagene Anmeldungen</de>
										</label>
										<view-ref view="admin/monitoring/failed-logins.view.xml"/>
									</tab>
									<tab id="sql-monitor">
										<label>
											<en>SQL</en>
											<de>SQL</de>
										</label>
										<view-ref view="admin/monitoring/sql-monitor.view.xml"/>
									</tab>
									<tab id="revision-monitor">
										<label>
											<en>Changes</en>
											<de>Änderungen</de>
										</label>
										<view-ref view="admin/monitoring/revision-monitor.view.xml"/>
									</tab>
								</tab-bar>
							</tab>
							<tab id="system">
								<label>
									<en>System</en>
									<de>System</de>
								</label>
								<tab-bar active-tab="services">
									<tab id="services">
										<label>
											<en>Services</en>
											<de>Dienste</de>
										</label>
										<view-ref view="admin/system/services.view.xml"/>
									</tab>
									<tab id="locks">
										<label>
											<en>Locks</en>
											<de>Sperren</de>
										</label>
										<view-ref view="admin/system/locks.view.xml"/>
									</tab>
									<tab id="maintenance">
										<label>
											<en>Maintenance mode</en>
											<de>Wartungsmodus</de>
										</label>
										<view-ref view="admin/system/maintenance.view.xml"/>
									</tab>
									<tab id="logs">
										<label>
											<en>Logs</en>
											<de>Protokolle</de>
										</label>
										<view-ref view="admin/system/logs.view.xml"/>
									</tab>
									<tab id="logger-levels">
										<label>
											<en>Log levels</en>
											<de>Protokollebenen</de>
										</label>
										<view-ref view="admin/system/logger-levels.view.xml"/>
									</tab>
								</tab-bar>
							</tab>
						</tab-bar>
					</extension>
				</extensions>
			</instance>
		</config>

		<config service-class="com.top_logic.layout.view.table.ColumnProviderService">
			<instance class="com.top_logic.layout.view.table.ColumnProviderService">
				<providers>
					<!--
						Built-in defaults (enumeration / number / date / boolean / string / label)
						are derived from the attribute type; register app-specific type providers here.
					-->
				</providers>
			</instance>
		</config>

		<config service-class="com.top_logic.layout.view.form.FieldControlService">
			<instance class="com.top_logic.layout.view.form.FieldControlService">
				<providers>
					<provider type="tl.core:Icon">
						<impl class="com.top_logic.layout.view.form.IconSelectControlProvider"/>
					</provider>
					<provider type="tl.model.i18n:I18NString">
						<impl class="com.top_logic.layout.view.form.I18NStringControlProvider"/>
					</provider>
					<provider type="tl.util:Color">
						<impl class="com.top_logic.layout.view.form.ColorInputControlProvider"/>
					</provider>
					<provider type="tl.util:Country">
						<impl class="com.top_logic.layout.view.form.SelectControlProvider">
							<option-provider class="com.top_logic.element.meta.complex.CountryOptionProvider"/>
						</impl>
					</provider>
					<provider type="tl.util:Language">
						<impl class="com.top_logic.layout.view.form.SelectControlProvider">
							<option-provider class="com.top_logic.element.meta.complex.LanguageOptionProvider"/>
						</impl>
					</provider>
					<provider type="tl.util:TimeZone">
						<impl class="com.top_logic.layout.view.form.SelectControlProvider">
							<option-provider class="com.top_logic.element.meta.complex.TimeZoneOptionProvider"/>
						</impl>
					</provider>
				</providers>
			</instance>
		</config>

		<!--
			Security scope for the reusable account / group / role administration views
			(WEB-INF/views/admin/admin.view.xml). Defined here in the framework so any app
			that includes this module inherits it and can gate an Administration entry with
			<access-control scope="administration"/> out of the box. With no roles assigned,
			the scope is visible only to the technical super user (root); other users are
			granted via the security administration UI. Apps may add further scopes by
			extending this service's <scopes> list.
		-->
		<config service-class="com.top_logic.layout.view.security.SecurityScopeService">
			<instance class="com.top_logic.layout.view.security.SecurityScopeService">
				<scopes>
					<scope id="administration">
						<label>
							<en>Administration</en>
							<de>Administration</de>
						</label>
					</scope>
				</scopes>
			</instance>
		</config>
	</services>

	<configs>
		<config config:interface="com.top_logic.base.accesscontrol.ApplicationPages$Config">
			<startPage>/view/</startPage>
		</config>
	</configs>
</application>
