<?xml version="1.0" encoding="utf-8" ?>

<view>
	<stack
		direction="column"
		gap="default"
	>
		<grid
			gap="default"
			min-column-width="16rem"
		>
			<card
				title="Active Tasks"
				variant="elevated"
			>
				<demo-counter label="Tasks"/>
			</card>
			<card title="In Review">
				<demo-counter label="Reviews"/>
			</card>
			<card title="Team Notes">
				<button>
					<action class="com.top_logic.demo.view.command.DemoCommand"
						label="Open Details"
					/>
				</button>
			</card>
			<card title="Quick Add">
				<button>
					<action class="com.top_logic.demo.view.command.DemoCommand"
						label="+ New Task"
					/>
				</button>
			</card>
		</grid>
	</stack>
</view>