<?xml version="1.0" encoding="utf-8" ?>

<!--
	Administration area for the React view UI. The outer tab-bar groups admin sections; each inner
	tab-bar holds that section's views. Add further admin sections as sibling tabs.
-->
<view>
	<tab-bar active-tab="access-control">
		<tabs>
			<tab id="access-control">
				<label>
					<en>Access control</en>
					<de>Zugriffskontrolle</de>
				</label>
				<tab-bar active-tab="accounts">
					<tabs>
						<tab id="accounts">
							<label>
								<en>Accounts</en>
								<de>Konten</de>
							</label>
							<view-ref view="admin/accounts.view.xml"/>
						</tab>
						<tab id="groups">
							<label>
								<en>Groups</en>
								<de>Gruppen</de>
							</label>
							<view-ref view="admin/groups.view.xml"/>
						</tab>
						<tab id="roles">
							<label>
								<en>Roles</en>
								<de>Rollen</de>
							</label>
							<view-ref view="admin/roles.view.xml"/>
						</tab>
						<tab id="permissions">
							<label>
								<en>Permissions</en>
								<de>Berechtigungen</de>
							</label>
							<view-ref view="admin/permissions.view.xml"/>
						</tab>
					</tabs>
				</tab-bar>
			</tab>
			<tab id="monitoring">
				<label>
					<en>Monitoring</en>
					<de>Überwachung</de>
				</label>
				<tab-bar active-tab="system-environment">
					<tabs>
						<tab id="system-environment">
							<label>
								<en>System environment</en>
								<de>Systemumgebung</de>
							</label>
							<view-ref view="admin/system-environment.view.xml"/>
						</tab>
						<tab id="application-monitor">
							<label>
								<en>Application</en>
								<de>Anwendung</de>
							</label>
							<view-ref view="admin/application-monitor.view.xml"/>
						</tab>
						<tab id="thread-monitor">
							<label>
								<en>Threads</en>
								<de>Threads</de>
							</label>
							<view-ref view="admin/thread-monitor.view.xml"/>
						</tab>
					</tabs>
				</tab-bar>
			</tab>
		</tabs>
	</tab-bar>
</view>