<?xml version="1.0" encoding="utf-8" ?>

<view>
	<panel title="Error Handling Demo">
		<button>
			<action class="com.top_logic.layout.view.command.GenericViewCommand"
				label="Throw TopLogicException"
			>
				<throw-error message="This is a test error from a TopLogicException."/>
			</action>
		</button>
		<button>
			<action class="com.top_logic.layout.view.command.GenericViewCommand"
				label="Throw KB error (wrapped)"
			>
				<with-transaction>
					<execute-script function="x -> new(`test.constraints:ConstraintTestType`)"/>
				</with-transaction>
			</action>
		</button>
	</panel>
</view>
